<%- include('partials/admin-header', {title: 'Waitlist Deposit Receipt | Admin', active: 'waitlist', heading: 'Waitlist Deposit Receipt'}) %>

<div class="admin-section" style="max-width:700px;">
  <div style="background:#1a2433;border:1px solid #c9a22740;border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#c9a227;font-size:0.85rem;">
    <i class="fa-solid fa-list-check"></i> This creates a <strong>Waitlist Deposit Receipt</strong> for <%= entry.name %> — a separate document from a puppy purchase invoice, with its own waitlist-specific terms.
  </div>

  <form method="POST" action="/admin/waitlist/<%= entry._id %>/deposit-invoice" id="waitlistInvoiceForm">

    <h3 style="color:#374151;margin-bottom:16px;font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #e5e7eb;padding-bottom:10px;">Client Details</h3>

    <div class="form-group">
      <label>Full Name *</label>
      <input type="text" name="clientName" value="<%= entry.name %>" required>
    </div>
    <div class="form-group">
      <label>Email *</label>
      <input type="email" name="clientEmail" value="<%= entry.email %>" required>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="clientPhone" value="<%= entry.phone || '' %>">
      </div>
      <div class="form-group">
        <label>Address / Location</label>
        <input type="text" name="clientAddress" value="<%= entry.location || '' %>">
      </div>
    </div>

    <h3 style="color:#374151;margin:24px 0 16px;font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #e5e7eb;padding-bottom:10px;">Preferences</h3>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
      <div class="form-group">
        <label>Preferred Gender</label>
        <input type="text" name="preferredGender" value="<%= entry.preferredGender %>">
      </div>
      <div class="form-group">
        <label>Preferred Color</label>
        <input type="text" name="preferredColor" value="<%= entry.preferredColor %>">
      </div>
    </div>

    <h3 style="color:#374151;margin:24px 0 16px;font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #e5e7eb;padding-bottom:10px;">Deposit</h3>

    <div class="form-group">
      <label>Deposit Amount ($) *</label>
      <input type="number" name="depositAmount" value="<%= entry.depositAmount %>" required>
    </div>
    <div class="form-group">
      <label>Additional Notes</label>
      <textarea name="notes" rows="3" placeholder="Any special notes…"><%= entry.notes || '' %></textarea>
    </div>

    <h3 style="color:#374151;margin:24px 0 16px;font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #e5e7eb;padding-bottom:10px;">Your Signature</h3>
    <div style="background:#fff;border-radius:8px;overflow:hidden;">
      <canvas id="sigPad" width="640" height="140" style="width:100%;height:140px;cursor:crosshair;touch-action:none;display:block;"></canvas>
    </div>
    <div style="display:flex;gap:10px;margin-top:8px;">
      <button type="button" onclick="clearSig()" style="background:#f9fafb;border:1px solid #d1d5db;color:#374151;padding:6px 14px;border-radius:6px;cursor:pointer;font-size:0.8rem;"><i class="fa-solid fa-eraser"></i> Clear</button>
    </div>
    <input type="hidden" name="signatureData" id="signatureData">

    <button type="submit" class="form-submit" style="margin-top:28px;" onclick="captureSig()">
      <i class="fa-solid fa-receipt"></i> Generate Receipt & Send to Client
    </button>
  </form>
</div>

<script>
const canvas = document.getElementById('sigPad');
const ctx = canvas.getContext('2d');
ctx.strokeStyle = '#1a1a1a'; ctx.lineWidth = 2.5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
let drawing = false, lastX = 0, lastY = 0;
function getPos(e) {
  const r = canvas.getBoundingClientRect();
  const sx = canvas.width/r.width, sy = canvas.height/r.height;
  if (e.touches) return { x:(e.touches[0].clientX-r.left)*sx, y:(e.touches[0].clientY-r.top)*sy };
  return { x:(e.clientX-r.left)*sx, y:(e.clientY-r.top)*sy };
}
canvas.addEventListener('mousedown', e=>{drawing=true;const p=getPos(e);lastX=p.x;lastY=p.y;});
canvas.addEventListener('mousemove', e=>{if(!drawing)return;const p=getPos(e);ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(p.x,p.y);ctx.stroke();lastX=p.x;lastY=p.y;});
canvas.addEventListener('mouseup', ()=>drawing=false);
canvas.addEventListener('mouseleave', ()=>drawing=false);
canvas.addEventListener('touchstart', e=>{e.preventDefault();drawing=true;const p=getPos(e);lastX=p.x;lastY=p.y;},{passive:false});
canvas.addEventListener('touchmove', e=>{e.preventDefault();if(!drawing)return;const p=getPos(e);ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(p.x,p.y);ctx.stroke();lastX=p.x;lastY=p.y;},{passive:false});
canvas.addEventListener('touchend', ()=>drawing=false);
function clearSig(){ctx.clearRect(0,0,canvas.width,canvas.height);}
function captureSig(){document.getElementById('signatureData').value=canvas.toDataURL('image/png');}
</script>

<%- include('partials/admin-footer') %>
