<%- include('partials/header', {title: 'Puppy Form | Admin'}) %>

<section class="page-section">
  <h1><%= puppy ? 'Edit Puppy' : 'Add New Puppy' %></h1>

  <form method="POST" action="<%= puppy ? '/admin/puppies/edit/' + puppy._id : '/admin/puppies/new' %>" class="contact-form" enctype="multipart/form-data">

    <div class="form-group">
      <label>Name *</label>
      <input type="text" name="name" value="<%= puppy ? puppy.name : '' %>" required>
    </div>

    <div class="form-group">
      <label>Price ($) *</label>
      <input type="number" name="price" value="<%= puppy ? puppy.price : '' %>" required>
    </div>

    <div class="form-group">
      <label>Gender *</label>
      <select name="gender" required style="width:100%;padding:12px;border:1px solid #ddd;border-radius:8px;">
        <option value="Male" <%= puppy && puppy.gender === 'Male' ? 'selected' : '' %>>Male</option>
        <option value="Female" <%= puppy && puppy.gender === 'Female' ? 'selected' : '' %>>Female</option>
      </select>
    </div>

    <div class="form-group">
      <label>Date of Birth *</label>
      <input type="date" name="dateOfBirth" value="<%= puppy ? puppy.dateOfBirth.toISOString().split('T')[0] : '' %>" required>
    </div>

    <div class="form-group">
      <label>Color *</label>
      <input type="text" name="color" value="<%= puppy ? puppy.color : '' %>" required>
    </div>

    <div class="form-group">
      <label>Weight</label>
      <input type="text" name="weight" value="<%= puppy ? puppy.weight : '' %>" placeholder="e.g. 3.5 lbs">
    </div>

    <div class="form-group">
      <label>Status *</label>
      <select name="status" required style="width:100%;padding:12px;border:1px solid #ddd;border-radius:8px;">
        <option value="Available" <%= puppy && puppy.status === 'Available' ? 'selected' : '' %>>Available</option>
        <option value="Reserved" <%= puppy && puppy.status === 'Reserved' ? 'selected' : '' %>>Reserved</option>
        <option value="Sold" <%= puppy && puppy.status === 'Sold' ? 'selected' : '' %>>Sold</option>
      </select>
    </div>

    <div class="form-group">
      <label>Description</label>
      <textarea name="description"><%= puppy ? puppy.description : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Sire (Father's Name)</label>
      <input type="text" name="sireName" value="<%= puppy ? puppy.sireName : '' %>">
    </div>

    <div class="form-group">
      <label>Dam (Mother's Name)</label>
      <input type="text" name="damName" value="<%= puppy ? puppy.damName : '' %>">
    </div>

    <div class="form-group">
      <label><input type="checkbox" name="vaccinated" <%= puppy && puppy.vaccinated ? 'checked' : '' %>> Vaccinated</label>
    </div>
    <div class="form-group">
      <label><input type="checkbox" name="dewormed" <%= puppy && puppy.dewormed ? 'checked' : '' %>> Dewormed</label>
    </div>
    <div class="form-group">
      <label><input type="checkbox" name="microchipped" <%= puppy && puppy.microchipped ? 'checked' : '' %>> Microchipped</label>
    </div>

    <div class="form-group">
      <label>Photos (you can select up to 5 at once)</label>
      <input type="file" name="photos" accept="image/*" multiple>
      <small style="color:#888;display:block;margin-top:4px;">Tip: Hold Ctrl (or Cmd) to select multiple photos. Uploading new photos replaces the old ones.</small>
      <% if (puppy && puppy.photos && puppy.photos.length > 0) { %>
        <p style="margin-top:8px;">Current photos:</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;">
          <% puppy.photos.forEach(function(p) { %>
            <img src="<%= p %>" style="max-width:90px;border-radius:8px;">
          <% }); %>
        </div>
      <% } %>
    </div>

    <button type="submit" class="form-submit"><%= puppy ? 'Update Puppy' : 'Add Puppy' %></button>
  </form>
</section>

<%- include('partials/footer') %>