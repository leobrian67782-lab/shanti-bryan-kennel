<%- include('partials/admin-header', {title: 'Puppy Form | Admin', active: 'puppy', heading: puppy ? 'Edit Puppy' : 'Add New Puppy'}) %>

<div class="admin-section" style="max-width:700px;">
  <form method="POST" action="<%= puppy ? '/admin/puppies/edit/' + puppy._id : '/admin/puppies/new' %>" enctype="multipart/form-data">

    <div class="form-group">
      <label>Name *</label>
      <input type="text" name="name" value="<%= puppy ? puppy.name : '' %>" required>
    </div>

    <div class="form-group">
      <label>Price ($) *</label>
      <input type="number" name="price" value="<%= puppy ? puppy.price : '' %>" required>
    </div>

    <div class="form-group">
      <label>Gender *</label>
      <select name="gender" required>
        <option value="Male" <%= puppy && puppy.gender === 'Male' ? 'selected' : '' %>>Male</option>
        <option value="Female" <%= puppy && puppy.gender === 'Female' ? 'selected' : '' %>>Female</option>
      </select>
    </div>

    <div class="form-group">
      <label>Date of Birth *</label>
      <input type="date" name="dateOfBirth" value="<%= puppy ? puppy.dateOfBirth.toISOString().split('T')[0] : '' %>" required>
    </div>

    <div class="form-group">
      <label>Color *</label>
      <input type="text" name="color" value="<%= puppy ? puppy.color : '' %>" required>
    </div>

    <div class="form-group">
      <label>Weight</label>
      <input type="text" name="weight" value="<%= puppy ? puppy.weight : '' %>" placeholder="e.g. 3.5 lbs">
    </div>

    <div class="form-group">
      <label>Status *</label>
      <select name="status" required>
        <option value="Available" <%= puppy && puppy.status === 'Available' ? 'selected' : '' %>>Available</option>
        <option value="Reserved" <%= puppy && puppy.status === 'Reserved' ? 'selected' : '' %>>Reserved</option>
        <option value="Sold" <%= puppy && puppy.status === 'Sold' ? 'selected' : '' %>>Sold</option>
      </select>
    </div>

    <div class="form-group">
      <label>Description</label>
      <textarea name="description"><%= puppy ? puppy.description : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Sire (Father's Name)</label>
      <input type="text" name="sireName" value="<%= puppy ? puppy.sireName : '' %>">
    </div>

    <div class="form-group">
      <label>Dam (Mother's Name)</label>
      <input type="text" name="damName" value="<%= puppy ? puppy.damName : '' %>">
    </div>

    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;font-weight:600;"><input type="checkbox" name="vaccinated" style="width:auto;" <%= puppy && puppy.vaccinated ? 'checked' : '' %>> Vaccinated</label>
    </div>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;font-weight:600;"><input type="checkbox" name="dewormed" style="width:auto;" <%= puppy && puppy.dewormed ? 'checked' : '' %>> Dewormed</label>
    </div>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;font-weight:600;"><input type="checkbox" name="microchipped" style="width:auto;" <%= puppy && puppy.microchipped ? 'checked' : '' %>> Microchipped</label>
    </div>

    <div class="form-group">
      <label>Photos (you can select up to 5 at once)</label>
      <input type="file" name="photos" accept="image/*" multiple>
      <small style="color:#7a8494;display:block;margin-top:4px;">Tip: Hold Ctrl (or Cmd) to select multiple photos. New photos are added to the gallery below, they won't remove your existing ones.</small>
      <% if (puppy && puppy.photos && puppy.photos.length > 0) { %>
        <p style="margin-top:14px;color:#c5cdd8;">Current photos <span style="color:#7a8494;font-weight:400;">(check a photo to remove it when you save)</span>:</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;">
          <% puppy.photos.forEach(function(p, i) { %>
            <label class="photo-remove-card" style="display:block;width:100px;flex-shrink:0;position:relative;border-radius:8px;overflow:hidden;cursor:pointer;">
              <img src="<%= p %>" alt="Photo <%= i + 1 %>" style="width:100px;height:100px;object-fit:cover;display:block;">
              <span class="photo-remove-overlay" style="display:flex;align-items:center;justify-content:center;gap:4px;font-size:0.68rem;font-weight:600;color:#e8848f;background:#1c2430;padding:5px 0;">
                <input type="checkbox" name="deletePhotos" value="<%= p %>" style="width:auto;margin:0;">
                <i class="fa-solid fa-trash"></i> Remove
              </span>
            </label>
          <% }); %>
        </div>
      <% } %>
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-floppy-disk"></i> <%= puppy ? 'Update Puppy' : 'Add Puppy' %></button>
  </form>
</div>

<%- include('partials/admin-footer') %>
