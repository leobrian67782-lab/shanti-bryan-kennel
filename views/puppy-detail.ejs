<%- include('partials/header', {title: puppy.name + ' | Shanti & Bryan Pinscher Kennel'}) %>

<section class="page-section">
  <div class="container" style="max-width: 950px;">
    <div class="detail-grid">

      <div>
        <% if (puppy.photos && puppy.photos.length > 0) { %>
          <div class="gallery">
            <img id="mainPhoto" src="<%= puppy.photos[0] %>" alt="<%= puppy.name %>" class="gallery-main" onclick="openLightbox(this.src)">
            <% if (puppy.photos.length > 1) { %>
              <div class="gallery-thumbs">
                <% puppy.photos.forEach(function(p, i) { %>
                  <img src="<%= p %>" alt="thumb" class="gallery-thumb <%= i === 0 ? 'active' : '' %>" onclick="setMain('<%= p %>', this)">
                <% }); %>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div style="width:100%;height:300px;background:#eee;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#999;">No photo</div>
        <% } %>
      </div>

      <div>
        <h1 class="detail-name"><%= puppy.name %></h1>
        <span class="status-badge status-<%= puppy.status.toLowerCase() %>" style="display:inline-block;"><%= puppy.status %></span>

        <p class="detail-price">$<%= puppy.price %></p>

        <div class="detail-specs">
          <div class="detail-spec-row">
            <span class="detail-spec-label">Gender</span>
            <span class="detail-spec-value"><%= puppy.gender %></span>
          </div>
          <div class="detail-spec-row">
            <span class="detail-spec-label">Color</span>
            <span class="detail-spec-value"><%= puppy.color %></span>
          </div>
          <% if (puppy.weight) { %>
            <div class="detail-spec-row">
              <span class="detail-spec-label">Weight</span>
              <span class="detail-spec-value"><%= puppy.weight %></span>
            </div>
          <% } %>
          <div class="detail-spec-row">
            <span class="detail-spec-label">Date of Birth</span>
            <span class="detail-spec-value"><%= puppy.dateOfBirth.toDateString() %></span>
          </div>
          <% if (puppy.sireName) { %>
            <div class="detail-spec-row">
              <span class="detail-spec-label">Sire</span>
              <span class="detail-spec-value"><%= puppy.sireName %></span>
            </div>
          <% } %>
          <% if (puppy.damName) { %>
            <div class="detail-spec-row">
              <span class="detail-spec-label">Dam</span>
              <span class="detail-spec-value"><%= puppy.damName %></span>
            </div>
          <% } %>
        </div>

        <div class="detail-care-badges">
          <% if (puppy.vaccinated) { %><span class="detail-care-badge"><i class="fa-solid fa-circle-check"></i> Vaccinated</span><% } %>
          <% if (puppy.dewormed) { %><span class="detail-care-badge"><i class="fa-solid fa-circle-check"></i> Dewormed</span><% } %>
          <% if (puppy.microchipped) { %><span class="detail-care-badge"><i class="fa-solid fa-circle-check"></i> Microchipped</span><% } %>
        </div>

        <a href="/contact" class="btn" style="margin-top: 8px;">Reserve <%= puppy.name %></a>
      </div>
    </div>

    <% if (puppy.description) { %>
      <div class="detail-about">
        <h2>About <%= puppy.name %></h2>
        <p><%= puppy.description %></p>
      </div>
    <% } %>

    <div class="detail-back">
      <a href="/puppies" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Back to All Puppies</a>
    </div>
  </div>
</section>

<script>
  function setMain(src, el) {
    document.getElementById('mainPhoto').src = src;
    document.querySelectorAll('.gallery-thumb').forEach(function(t) { t.classList.remove('active'); });
    el.classList.add('active');
  }
</script>

<%- include('partials/footer') %>
