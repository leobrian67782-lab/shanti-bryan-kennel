<%- include('partials/admin-header', {title: 'Post Form | Admin', active: 'post', heading: post ? 'Edit Post' : 'New Post'}) %>

<div class="admin-section" style="max-width:760px;">
  <form method="POST" action="<%= post ? '/admin/posts/edit/' + post._id : '/admin/posts/new' %>" enctype="multipart/form-data">

    <div class="form-group">
      <label>Title *</label>
      <input type="text" name="title" value="<%= post ? post.title : '' %>" required>
    </div>

    <div class="form-group">
      <label>Short Excerpt (shown in the blog list)</label>
      <input type="text" name="excerpt" value="<%= post ? post.excerpt : '' %>" placeholder="A one-line summary of the post">
    </div>

    <div class="form-group">
      <label>Content *</label>
      <textarea name="content" required style="min-height:280px;" placeholder="Write your post here. Leave a blank line between paragraphs."><%= post ? post.content : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Featured Image</label>
      <input type="file" name="image" accept="image/*">
      <% if (post && post.image) { %>
        <img src="<%= post.image %>" style="max-width:160px;border-radius:8px;margin-top:8px;">
      <% } %>
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-floppy-disk"></i> <%= post ? 'Update Post' : 'Publish Post' %></button>
  </form>
</div>

<%- include('partials/admin-footer') %>