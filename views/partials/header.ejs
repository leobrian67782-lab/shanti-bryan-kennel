<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <!-- SEO meta description -->
  <% var metaDesc = typeof description !== 'undefined' && description ? description : 'Shanti & Bryan Pinscher Kennel — home-raised Miniature Pinscher puppies placed in loving families worldwide. Health guaranteed, vaccinated, and socialized.'; %>
  <meta name="description" content="<%= metaDesc %>">

  <!-- Open Graph — controls how links look when shared on WhatsApp, Facebook, iMessage etc -->
  <% var ogImage = typeof ogImg !== 'undefined' && ogImg ? ogImg : 'https://shantibryankennel.com/images/images/emblem.png'; %>
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="Shanti & Bryan Pinscher Kennel">
  <meta property="og:title"       content="<%= title %>">
  <meta property="og:description" content="<%= metaDesc %>">
  <meta property="og:image"       content="<%= ogImage %>">
  <meta property="og:url"         content="https://shantibryankennel.com<%= typeof reqPath !== 'undefined' ? reqPath : '' %>">

  <!-- Twitter / X card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= title %>">
  <meta name="twitter:description" content="<%= metaDesc %>">
  <meta name="twitter:image"       content="<%= ogImage %>">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/png" href="/images/favicon-32.png">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
</head>
<body>
  <!-- Loading animation (home page only) -->
  <% if (typeof showLoader !== 'undefined' && showLoader) { %>
    <div id="loader" class="loader">
      <div class="loader-ring">
        <img src="/images/emblem.png" alt="Loading" class="loader-logo">
      </div>
      <p class="loader-text">Shanti & Bryan Pinscher Kennel</p>
    </div>
  <% } %>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <img src="/images/emblem.png" alt="Shanti & Bryan Pinscher Kennel" class="logo-img">
        <span class="logo-text">Shanti & Bryan <span>Pinscher Kennel</span></span>
      </a>

      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>

      <div class="nav-overlay" id="navOverlay"></div>
      <nav class="main-nav" id="mainNav">
        <a href="/">Home</a>
        <a href="/puppies">Available Puppies</a>
        <a href="/apply">Puppy Application</a>
        <a href="/waitlist">Join Waitlist</a>
        <a href="/our-dogs">Our Dogs</a>
        <a href="/litters">Litters</a>
        <a href="/about">About Us</a>
        <a href="/contact">Contact Us</a>
      </nav>
    </div>
  </header>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var toggle = document.getElementById('menuToggle');
      var nav = document.getElementById('mainNav');
      var overlay = document.getElementById('navOverlay');
      if (toggle && nav) {
        toggle.addEventListener('click', function() {
          nav.classList.toggle('nav-open');
          toggle.classList.toggle('active');
          if (overlay) overlay.classList.toggle('show');
        });
      }
      if (overlay) {
        overlay.addEventListener('click', function() {
          nav.classList.remove('nav-open');
          toggle.classList.remove('active');
          overlay.classList.remove('show');
        });
      }
    });
  </script>

  <main>
