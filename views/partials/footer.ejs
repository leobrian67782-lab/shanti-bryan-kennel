        <h3 class="footer-logo">Shanti & Bryan <span>Pinscher Kennel</span></h3>
        <p class="footer-about">Raising healthy, well-socialized Miniature Pinschers with love, health, and care.</p>
      </div>

      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/puppies">Available Puppies</a></li>
          <li><a href="/litters">Litters</a></li>
          <li><a href="/testimonials">Testimonials</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Get In Touch</h4>
        <% if (settings && settings.email) { %>
          <p class="footer-contact"><i class="fa-solid fa-envelope" style="color:var(--gold);margin-right:8px;"></i><a href="mailto:<%= settings.email %>"><%= settings.email %></a></p>
        <% } %>
        <% if (settings && settings.phone) { %>
          <p class="footer-contact"><i class="fa-solid fa-phone" style="color:var(--gold);margin-right:8px;"></i><a href="tel:<%= settings.phone %>"><%= settings.phone %></a></p>
