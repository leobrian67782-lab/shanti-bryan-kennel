  <script>
    function openLightbox(src) {
      document.getElementById('lightbox-img').src = src;
      document.getElementById('lightbox').style.display = 'flex';
    }
    function closeLightbox() {
      document.getElementById('lightbox').style.display = 'none';
    }

    window.addEventListener('load', function() {
      var loader = document.getElementById('loader');
      if (loader) {
        if (sessionStorage.getItem('visited')) {
          loader.style.display = 'none';
        } else {
          setTimeout(function() {
            loader.classList.add('loader-hidden');
            sessionStorage.setItem('visited', 'true');
          }, 1500);
        }
      }
    });

    document.addEventListener('DOMContentLoaded', function() {
      var revealEls = document.querySelectorAll('.reveal');
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('revealed'); }
        });
      }, { threshold: 0.15 });
      revealEls.forEach(function(el) { observer.observe(el); });

      var counters = document.querySelectorAll('.counter, .counter-percent');
      var counterObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && !entry.target.dataset.done) {
            entry.target.dataset.done = 'true';
            var target = parseInt(entry.target.dataset.target);
            var isPercent = entry.target.classList.contains('counter-percent');
            var count = 0;
            var step = Math.ceil(target / 50);
            var timer = setInterval(function() {
              count += step;
              if (count >= target) { count = target; clearInterval(timer); }
              entry.target.textContent = count + (isPercent ? '%' : '+');
            }, 30);
          }
        });
      }, { threshold: 0.5 });
      counters.forEach(function(c) { counterObserver.observe(c); });

      var backToTop = document.getElementById('backToTop');
      if (backToTop) {
        window.addEventListener('scroll', function() {
          if (window.scrollY > 400) { backToTop.classList.add('show'); }
          else { backToTop.classList.remove('show'); }
        });
        backToTop.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    });
  </script>

  <!-- Universal image compressor: runs in the browser before upload,
       shrinks photos to max 1200px / 70% quality so uploads are 5-10x faster.
       Works automatically on every file input that accepts images, on every page. -->
  <script>
    (function() {
      var MAX_PX  = 1200;  // max width or height in pixels
      var QUALITY = 0.72;  // JPEG quality (0–1). 0.72 = good balance of size vs quality

      function compressFile(file, done) {
        if (!file.type.startsWith('image/')) return done(file);
        var reader = new FileReader();
        reader.onload = function(e) {
          var img = new Image();
          img.onload = function() {
            var w = img.width, h = img.height;
            if (w <= MAX_PX && h <= MAX_PX) return done(file); // already small enough
            var ratio = Math.min(MAX_PX / w, MAX_PX / h);
            var canvas = document.createElement('canvas');
            canvas.width  = Math.round(w * ratio);
            canvas.height = Math.round(h * ratio);
            canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
            canvas.toBlob(function(blob) {
              var compressed = new File([blob], file.name, { type: 'image/jpeg', lastModified: Date.now() });
              done(compressed);
            }, 'image/jpeg', QUALITY);
          };
          img.src = e.target.result;
        };
        reader.readAsDataURL(file);
      }

      function compressAndSubmit(form, submitBtn) {
        var inputs = form.querySelectorAll('input[type="file"][accept*="image"]');
        var pending = 0;

        inputs.forEach(function(input) {
          if (!input.files || !input.files.length) return;
          pending++;
        });

        if (pending === 0) { form.submit(); return; }

        var done = 0;
        inputs.forEach(function(input) {
          if (!input.files || !input.files.length) return;
          var files = Array.from(input.files);
          var compressed = [];
          var filesDone = 0;

          files.forEach(function(file, i) {
            compressFile(file, function(result) {
              compressed[i] = result;
              filesDone++;
              if (filesDone === files.length) {
                var dt = new DataTransfer();
                compressed.forEach(function(f) { dt.items.add(f); });
                input.files = dt.files;
                done++;
                if (done === pending) form.submit();
              }
            });
          });
        });
      }

      document.addEventListener('submit', function(e) {
        var form = e.target;
        var hasImageInput = form.querySelector('input[type="file"][accept*="image"]');
        if (!hasImageInput) return;

        var hasFiles = false;
        form.querySelectorAll('input[type="file"][accept*="image"]').forEach(function(inp) {
          if (inp.files && inp.files.length) hasFiles = true;
        });
        if (!hasFiles) return;

        e.preventDefault();

        // Show loading overlay
        var overlay = document.createElement('div');
        overlay.id = 'upload-overlay';
        overlay.innerHTML = '<div style="text-align:center;">' +
          '<div style="width:52px;height:52px;border:4px solid rgba(201,162,39,0.3);border-top-color:#c9a227;border-radius:50%;animation:spin 0.9s linear infinite;margin:0 auto 18px;"></div>' +
          '<p style="color:#fff;font-family:Poppins,sans-serif;font-weight:600;margin:0;">Uploading photo<span id="upload-dots">...</span></p>' +
          '<p style="color:#c5cdd8;font-family:Poppins,sans-serif;font-size:0.85rem;margin-top:6px;">Compressing & sending, please wait</p>' +
          '</div>';
        overlay.style.cssText = 'position:fixed;inset:0;background:rgba(10,14,20,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;';
        document.body.appendChild(overlay);

        compressAndSubmit(form, null);
      });
    })();
  </script>
