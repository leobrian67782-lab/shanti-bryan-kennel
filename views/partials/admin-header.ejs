<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/png" href="/images/favicon-32.png">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
</head>
<body>
  <%
    // Map each page to its section for the eyebrow label
    var sectionMap = {
      dashboard: 'Overview',
      puppy: 'Kennel', litter: 'Kennel', dog: 'Kennel',
      inquiries: 'Pipeline', applications: 'Pipeline', waitlist: 'Pipeline', invoice: 'Pipeline', certificate: 'Pipeline',
      testimonial: 'Website', faq: 'Website', post: 'Website',
      settings: 'Configuration'
    };
    var sectionName = sectionMap[active] || 'Admin';
  %>
  <div class="admin-layout" id="adminLayout">

    <div class="admin-sidebar-backdrop" id="adminSidebarBackdrop"></div>

    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-brand">
        <img src="/images/emblem.png" alt="Shanti & Bryan Pinscher Kennel" class="admin-brand-img">
        <div>
          <span class="admin-brand-name">Shanti &amp; Bryan</span>
          <span class="admin-brand-sub">Kennel Registry</span>
        </div>
      </div>

      <nav class="admin-nav">
        <p class="admin-nav-group">Overview</p>
        <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>"><i class="fa-solid fa-table-columns"></i> Dashboard</a>

        <p class="admin-nav-group">Kennel</p>
        <a href="/admin/puppies" class="<%= active === 'puppy' ? 'active' : '' %>"><i class="fa-solid fa-heart"></i> Puppies</a>
        <a href="/admin/litters" class="<%= active === 'litter' ? 'active' : '' %>"><i class="fa-solid fa-paw"></i> Litters</a>
        <a href="/admin/dogs" class="<%= active === 'dog' ? 'active' : '' %>"><i class="fa-solid fa-dog"></i> Our Dogs</a>

        <p class="admin-nav-group">Pipeline</p>
        <a href="/admin/inquiries" class="<%= active === 'inquiries' ? 'active' : '' %>"><i class="fa-solid fa-envelope"></i> Messages</a>
        <a href="/admin/applications" class="<%= active === 'applications' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-list"></i> Applications</a>
        <a href="/admin/waitlist" class="<%= active === 'waitlist' ? 'active' : '' %>"><i class="fa-solid fa-list-check"></i> Waitlist</a>
        <a href="/admin/invoices" class="<%= active === 'invoice' ? 'active' : '' %>"><i class="fa-solid fa-file-invoice-dollar"></i> Invoices</a>
        <a href="/admin/certificates" class="<%= active === 'certificate' ? 'active' : '' %>"><i class="fa-solid fa-certificate"></i> Certificates</a>

        <p class="admin-nav-group">Website</p>
        <a href="/admin/testimonials" class="<%= active === 'testimonial' ? 'active' : '' %>"><i class="fa-solid fa-star"></i> Testimonials</a>
        <a href="/admin/faqs" class="<%= active === 'faq' ? 'active' : '' %>"><i class="fa-solid fa-circle-question"></i> FAQs</a>
        <a href="/admin/posts" class="<%= active === 'post' ? 'active' : '' %>"><i class="fa-solid fa-newspaper"></i> Blog Posts</a>

        <p class="admin-nav-group">Configuration</p>
        <a href="/admin/settings" class="<%= active === 'settings' ? 'active' : '' %>"><i class="fa-solid fa-gear"></i> Site Settings</a>
        <a href="/" target="_blank"><i class="fa-solid fa-arrow-up-right-from-square"></i> View Live Site</a>

        <a href="/admin/logout" class="admin-logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
      </nav>
    </aside>

    <!-- Main column -->
    <div class="admin-main">
      <header class="admin-topbar">
        <button class="admin-menu-toggle" id="adminMenuToggle" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
        <div class="admin-topbar-titles">
          <span class="admin-topbar-eyebrow"><%= sectionName %></span>
          <h2><%= heading %></h2>
        </div>
        <a href="/" target="_blank" class="admin-topnav-icon-btn" title="View Live Site"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
        <div class="admin-avatar">A</div>
      </header>

      <div class="admin-content">
