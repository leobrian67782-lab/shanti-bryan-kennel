<%- include('partials/admin-header', {title: 'Dog Form | Admin', active: 'dog', heading: dog ? 'Edit Dog' : 'Add Dog'}) %>

<div class="admin-section" style="max-width:640px;">
  <form method="POST" action="<%= dog ? '/admin/dogs/edit/' + dog._id : '/admin/dogs/new' %>" enctype="multipart/form-data">

    <div class="form-group">
      <label>Name *</label>
      <input type="text" name="name" value="<%= dog ? dog.name : '' %>" required>
    </div>

    <div class="form-group">
      <label>Gender *</label>
      <select name="gender" required>
        <option value="Male" <%= dog && dog.gender === 'Male' ? 'selected' : '' %>>Male</option>
        <option value="Female" <%= dog && dog.gender === 'Female' ? 'selected' : '' %>>Female</option>
      </select>
    </div>

    <div class="form-group">
      <label>Role / Title (optional)</label>
      <input type="text" name="role" value="<%= dog ? dog.role : '' %>" placeholder="e.g. Sire, Dam, Foundation Female">
    </div>

    <div class="form-group">
      <label>Display Order (lower shows first)</label>
      <input type="number" name="order" value="<%= dog ? dog.order : 0 %>">
    </div>

    <div class="form-group">
      <label>Description</label>
      <textarea name="description"><%= dog ? dog.description : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Photos (you can select up to 8 at once)</label>
      <input type="file" name="photos" accept="image/*" multiple>
      <small style="color:#7a8494;display:block;margin-top:4px;">Tip: Hold Ctrl (or Cmd) to select multiple photos. New photos are added to the gallery below, they won't remove your existing ones.</small>
      <%
        var existingDogPhotos = [];
        if (dog) {
          existingDogPhotos = (dog.photos && dog.photos.length > 0) ? dog.photos : (dog.photo ? [dog.photo] : []);
        }
      %>
      <% if (existingDogPhotos.length > 0) { %>
        <p style="margin-top:14px;color:#c5cdd8;">Current photos <span style="color:#7a8494;font-weight:400;">(check a photo to remove it when you save)</span>:</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;">
          <% existingDogPhotos.forEach(function(p, i) { %>
            <label class="photo-remove-card" style="display:block;width:100px;flex-shrink:0;position:relative;border-radius:8px;overflow:hidden;cursor:pointer;">
              <img src="<%= p %>" alt="Photo <%= i + 1 %>" style="width:100px;height:100px;object-fit:cover;display:block;">
              <span class="photo-remove-overlay" style="display:flex;align-items:center;justify-content:center;gap:4px;font-size:0.68rem;font-weight:600;color:#e8848f;background:#1c2430;padding:5px 0;">
                <input type="checkbox" name="deletePhotos" value="<%= p %>" style="width:auto;margin:0;">
                <i class="fa-solid fa-trash"></i> Remove
              </span>
            </label>
          <% }); %>
        </div>
      <% } %>
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-floppy-disk"></i> <%= dog ? 'Update Dog' : 'Add Dog' %></button>
  </form>
</div>

<%- include('partials/admin-footer') %>
