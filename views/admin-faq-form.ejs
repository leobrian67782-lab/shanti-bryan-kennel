<%- include('partials/admin-header', {title: 'FAQ Form | Admin', active: 'faq', heading: faq ? 'Edit FAQ' : 'Add New FAQ'}) %>

<div class="admin-section" style="max-width:640px;">
  <form method="POST" action="<%= faq ? '/admin/faqs/edit/' + faq._id : '/admin/faqs/new' %>">

    <div class="form-group">
      <label>Question *</label>
      <input type="text" name="question" value="<%= faq ? faq.question : '' %>" required>
    </div>

    <div class="form-group">
      <label>Answer *</label>
      <textarea name="answer" required><%= faq ? faq.answer : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Display Order (lower = shows first)</label>
      <input type="number" name="order" value="<%= faq ? faq.order : 0 %>">
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-floppy-disk"></i> <%= faq ? 'Update FAQ' : 'Add FAQ' %></button>
  </form>
</div>

<%- include('partials/admin-footer') %>
