<%- include('partials/admin-header', {title: 'Litter Form | Admin', active: 'litter', heading: litter ? 'Edit Litter' : 'Add New Litter'}) %>

<div class="admin-section" style="max-width:700px;">
  <form method="POST" action="<%= litter ? '/admin/litters/edit/' + litter._id : '/admin/litters/new' %>" enctype="multipart/form-data">

    <div class="form-group">
      <label>Litter Name *</label>
      <input type="text" name="litterName" value="<%= litter ? litter.litterName : '' %>" required>
    </div>

    <div class="form-group">
      <label>Birth Date *</label>
      <input type="date" name="birthDate" value="<%= litter ? litter.birthDate.toISOString().split('T')[0] : '' %>" required>
    </div>

    <div class="form-group">
      <label>Number of Puppies</label>
      <input type="number" name="numberOfPuppies" value="<%= litter ? litter.numberOfPuppies : '' %>">
    </div>

    <div class="form-group">
      <label>Description</label>
      <textarea name="description"><%= litter ? litter.description : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Litter Photos (you can select up to 20 at once)</label>
      <input type="file" name="photos" accept="image/*" multiple>
      <small style="color:#6b7280;display:block;margin-top:4px;">Tip: Hold Ctrl (or Cmd) to select multiple photos. New photos are added to the gallery below, they won't remove your existing ones.</small>
      <% if (litter && litter.photos && litter.photos.length > 0) { %>
        <p style="margin-top:14px;color:#374151;">Current photos <span style="color:#6b7280;font-weight:400;">(check a photo to remove it when you save)</span>:</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;">
          <% litter.photos.forEach(function(p, i) { %>
            <label class="photo-remove-card" style="display:block;width:100px;flex-shrink:0;position:relative;border-radius:8px;overflow:hidden;cursor:pointer;">
              <img src="<%= p %>" alt="Photo <%= i + 1 %>" style="width:100px;height:100px;object-fit:cover;display:block;">
              <span class="photo-remove-overlay" style="display:flex;align-items:center;justify-content:center;gap:4px;font-size:0.68rem;font-weight:600;color:#dc2626;background:#f9fafb;padding:5px 0;">
                <input type="checkbox" name="deletePhotos" value="<%= p %>" style="width:auto;margin:0;">
                <i class="fa-solid fa-trash"></i> Remove
              </span>
            </label>
          <% }); %>
        </div>
      <% } %>
    </div>

    <hr style="margin:30px 0;border:none;border-top:1px solid #e5e7eb;">
    <h3 style="text-align:left;margin-bottom:16px;color:#374151;">Sire (Father)</h3>

    <div class="form-group">
      <label>Sire Name *</label>
      <input type="text" name="sireName" value="<%= litter ? litter.sireName : '' %>" required>
    </div>
    <div class="form-group">
      <label>Sire Weight</label>
      <input type="text" name="sireWeight" value="<%= litter ? litter.sireWeight : '' %>" placeholder="e.g. 9 lbs">
    </div>
    <div class="form-group">
      <label>Sire Photo</label>
      <input type="file" name="sirePhoto" accept="image/*">
      <% if (litter && litter.sirePhoto) { %>
        <img src="<%= litter.sirePhoto %>" style="max-width:120px;border-radius:8px;margin-top:6px;">
      <% } %>
    </div>

    <hr style="margin:30px 0;border:none;border-top:1px solid #e5e7eb;">
    <h3 style="text-align:left;margin-bottom:16px;color:#374151;">Dam (Mother)</h3>

    <div class="form-group">
      <label>Dam Name *</label>
      <input type="text" name="damName" value="<%= litter ? litter.damName : '' %>" required>
    </div>
    <div class="form-group">
      <label>Dam Weight</label>
      <input type="text" name="damWeight" value="<%= litter ? litter.damWeight : '' %>" placeholder="e.g. 8 lbs">
    </div>
    <div class="form-group">
      <label>Dam Photo</label>
      <input type="file" name="damPhoto" accept="image/*">
      <% if (litter && litter.damPhoto) { %>
        <img src="<%= litter.damPhoto %>" style="max-width:120px;border-radius:8px;margin-top:6px;">
      <% } %>
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-floppy-disk"></i> <%= litter ? 'Update Litter' : 'Add Litter' %></button>
  </form>
</div>

<%- include('partials/admin-footer') %>
