<%- include('partials/admin-header', {title: 'Applications | Admin', active: 'applications', heading: 'Puppy Applications'}) %>

<div class="admin-board">

  <div class="admin-board-col col-gold">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Pending Review</span>
      <span class="admin-board-col-count"><%= pending.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (pending.length === 0) { %>
        <div class="admin-board-empty">Nothing waiting on you.</div>
      <% } %>
      <% pending.forEach(function(a) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= a.applicantName %></div>
          <div class="admin-board-card-sub"><%= a.interestedIn %> · <%= a.homeOwnership %></div>
          <div class="admin-board-card-meta"><%= a.createdAt.toLocaleDateString() %></div>
          <div class="admin-board-card-actions">
            <a href="/admin/applications/<%= a._id %>" class="admin-board-btn"><i class="fa-solid fa-eye"></i> View</a>
            <a href="/admin/applications/<%= a._id %>/approve" class="admin-board-btn admin-board-btn-primary"><i class="fa-solid fa-check"></i> Approve</a>
            <a href="/admin/applications/<%= a._id %>/decline" class="admin-board-btn admin-board-btn-danger" onclick="return confirm('Decline this application?')"><i class="fa-solid fa-xmark"></i></a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="admin-board-col col-green">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Approved</span>
      <span class="admin-board-col-count"><%= approved.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (approved.length === 0) { %>
        <div class="admin-board-empty">No approved applications yet.</div>
      <% } %>
      <% approved.forEach(function(a) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= a.applicantName %></div>
          <div class="admin-board-card-sub"><%= a.interestedIn %> · <%= a.homeOwnership %></div>
          <div class="admin-board-card-meta"><%= a.createdAt.toLocaleDateString() %></div>
          <div class="admin-board-card-actions">
            <a href="/admin/applications/<%= a._id %>" class="admin-board-btn"><i class="fa-solid fa-eye"></i> View</a>
            <a href="/admin/invoices/new" class="admin-board-btn admin-board-btn-primary"><i class="fa-solid fa-file-invoice-dollar"></i> Invoice</a>
            <a href="/admin/applications/<%= a._id %>/delete" class="admin-board-btn admin-board-btn-danger" onclick="return confirm('Delete this application?')"><i class="fa-solid fa-trash"></i></a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="admin-board-col col-red">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Declined</span>
      <span class="admin-board-col-count"><%= declined.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (declined.length === 0) { %>
        <div class="admin-board-empty">No declined applications.</div>
      <% } %>
      <% declined.forEach(function(a) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= a.applicantName %></div>
          <div class="admin-board-card-sub"><%= a.interestedIn %> · <%= a.homeOwnership %></div>
          <div class="admin-board-card-meta"><%= a.createdAt.toLocaleDateString() %></div>
          <div class="admin-board-card-actions">
            <a href="/admin/applications/<%= a._id %>" class="admin-board-btn"><i class="fa-solid fa-eye"></i> View</a>
            <a href="/admin/applications/<%= a._id %>/delete" class="admin-board-btn admin-board-btn-danger" onclick="return confirm('Delete this application?')"><i class="fa-solid fa-trash"></i> Delete</a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

</div>

<%- include('partials/admin-footer') %>
