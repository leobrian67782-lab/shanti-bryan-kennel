<%- include('partials/admin-header', {title: 'Dashboard | Admin', active: 'dashboard', heading: 'Dashboard Overview'}) %>

<!-- Summary cards -->
<div class="admin-overview-grid">
  <div class="admin-overview-card card-gold">
    <div class="admin-overview-icon"><i class="fa-solid fa-heart"></i></div>
    <div>
      <span class="admin-overview-num"><%= puppies.length %></span>
      <span class="admin-overview-label">Total Puppies</span>
      <span class="admin-overview-sub">
        <span style="color:#2e9e4f;"><%= puppies.filter(p => p.status === 'Available').length %> available</span> •
        <span style="color:var(--gold);"><%= puppies.filter(p => p.status === 'Reserved').length %> reserved</span> •
        <span style="color:var(--text-light);"><%= puppies.filter(p => p.status === 'Sold').length %> sold</span>
      </span>
    </div>
  </div>

  <div class="admin-overview-card card-blue">
    <div class="admin-overview-icon"><i class="fa-solid fa-newspaper"></i></div>
    <div>
      <span class="admin-overview-num"><%= posts.length %></span>
      <span class="admin-overview-label">Blog Posts</span>
      <span class="admin-overview-sub">
        <span style="color:#2e9e4f;"><%= posts.filter(p => p.published).length %> published</span> •
        <span style="color:var(--gold);"><%= posts.filter(p => !p.published).length %> drafts</span>
      </span>
    </div>
  </div>

  <div class="admin-overview-card card-red">
    <div class="admin-overview-icon"><i class="fa-solid fa-envelope"></i></div>
    <div>
      <span class="admin-overview-num"><%= inquiries.length %></span>
      <span class="admin-overview-label">Messages</span>
      <span class="admin-overview-sub"><%= inquiries.length %> total messages received</span>
    </div>
  </div>

  <div class="admin-overview-card card-green">
    <div class="admin-overview-icon"><i class="fa-solid fa-star"></i></div>
    <div>
      <span class="admin-overview-num"><%= testimonials.length %></span>
      <span class="admin-overview-label">Testimonials</span>
      <span class="admin-overview-sub">
        Customer reviews & success stories
        <% if (typeof pendingReviews !== 'undefined' && pendingReviews > 0) { %>
          <br><a href="/admin/testimonials" style="color:var(--gold);font-weight:700;"><i class="fa-solid fa-clock"></i> <%= pendingReviews %> pending approval</a>
        <% } %>
      </span>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-bolt" style="color:var(--gold);"></i> Quick Actions</h3>
  </div>
  <div class="admin-quick-grid">
    <a href="/admin/puppies/new" class="admin-quick-card admin-quick-primary">
      <i class="fa-solid fa-plus"></i>
      <span>Add Puppy</span>
    </a>
    <a href="/admin/posts/new" class="admin-quick-card admin-quick-outline">
      <i class="fa-solid fa-pen"></i>
      <span>New Post</span>
    </a>
    <a href="/admin/inquiries" class="admin-quick-card">
      <i class="fa-solid fa-envelope"></i>
      <span>Messages (<%= inquiries.length %>)</span>
    </a>
    <a href="/admin/testimonials/new" class="admin-quick-card">
      <i class="fa-solid fa-star"></i>
      <span>Add Review</span>
    </a>
    <a href="/admin/faqs/new" class="admin-quick-card">
      <i class="fa-solid fa-circle-question"></i>
      <span>Add FAQ</span>
    </a>
    <a href="/admin/settings" class="admin-quick-card">
      <i class="fa-solid fa-gear"></i>
      <span>Settings</span>
    </a>
  </div>
</div>

<!-- Recent Messages -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-envelope" style="color:var(--maroon);"></i> Recent Messages</h3>
    <a href="/admin/inquiries" class="admin-btn admin-btn-ghost">View All</a>
  </div>
  <% if (inquiries.length === 0) { %>
    <p class="admin-empty">No messages yet.</p>
  <% } else { %>
    <% inquiries.slice(0, 5).forEach(function(inq) { %>
      <div class="admin-recent-row">
        <div>
          <span class="admin-recent-title"><%= inq.name %></span>
          <span class="admin-recent-sub"><%= inq.subject %></span>
        </div>
        <div style="text-align:right;">
          <span class="admin-badge-new">NEW</span>
          <span class="admin-recent-date"><%= inq.createdAt.toLocaleDateString() %></span>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<!-- Recent Puppies -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-heart" style="color:var(--gold);"></i> Recent Puppies</h3>
    <a href="/admin/puppies" class="admin-btn admin-btn-ghost">View All</a>
  </div>
  <% if (puppies.length === 0) { %>
    <p class="admin-empty">No puppies yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Name</th><th>Status</th><th>Price</th><th>Added</th><th></th></tr></thead>
      <tbody>
        <% puppies.slice(0, 5).forEach(function(p) { %>
          <tr>
            <td>
              <span style="font-weight:600;"><%= p.name %></span><br>
              <span style="color:var(--text-light);font-size:0.82rem;"><%= p.gender %> • <%= p.color %></span>
            </td>
            <td><span class="status-badge status-<%= p.status.toLowerCase() %>"><%= p.status %></span></td>
            <td style="color:var(--maroon);font-weight:600;">$<%= p.price %></td>
            <td style="color:var(--text-light);font-size:0.85rem;"><%= p.createdAt.toLocaleDateString() %></td>
            <td class="admin-actions">
              <a href="/admin/puppies/edit/<%= p._id %>" class="admin-btn-sm"><i class="fa-solid fa-pen"></i></a>
              <a href="/admin/puppies/delete/<%= p._id %>" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Delete this puppy?')"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- Recent Blog Posts -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-newspaper" style="color:#2b6cb0;"></i> Recent Blog Posts</h3>
    <a href="/admin/posts" class="admin-btn admin-btn-ghost">View All</a>
  </div>
  <% if (posts.length === 0) { %>
    <p class="admin-empty">No posts yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Status</th><th>Date</th><th></th></tr></thead>
      <tbody>
        <% posts.slice(0, 5).forEach(function(p) { %>
          <tr>
            <td><%= p.title %></td>
            <td><span class="status-badge status-available">Published</span></td>
            <td style="color:var(--text-light);font-size:0.85rem;"><%= p.createdAt.toLocaleDateString() %></td>
            <td class="admin-actions">
              <a href="/blog/<%= p.slug %>" target="_blank" class="admin-btn-sm"><i class="fa-solid fa-eye"></i></a>
              <a href="/admin/posts/edit/<%= p._id %>" class="admin-btn-sm"><i class="fa-solid fa-pen"></i></a>
              <a href="/admin/posts/delete/<%= p._id %>" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Delete this post?')"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- Admin AI Assistant -->
<div class="admin-section" style="margin-top:24px;">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-robot" style="color:var(--gold);"></i> AI Assistant</h3>
    <span style="color:#6b7585;font-size:0.8rem;">Knows everything about your site in real time</span>
  </div>
  <div id="adminChatMsgs" style="min-height:120px;max-height:360px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding:4px 0 12px;"></div>
  <div style="display:flex;gap:8px;margin-top:12px;align-items:flex-end;">
    <textarea id="adminChatInp" placeholder="Ask anything — puppy stats, draft a description, reply to a customer…" style="flex:1;background:#1c2430;border:1.5px solid #2a3441;color:#fff;border-radius:8px;padding:10px 12px;font-family:'Poppins',sans-serif;font-size:0.85rem;resize:none;outline:none;line-height:1.5;max-height:80px;" rows="2"></textarea>
    <button id="adminChatSend" style="background:var(--gold);color:#0d1117;border:none;border-radius:8px;width:42px;height:42px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="fa-solid fa-paper-plane"></i></button>
  </div>
  <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;" id="adminChatQR"></div>
</div>

<script>
(function() {
  const msgs = document.getElementById('adminChatMsgs');
  const inp  = document.getElementById('adminChatInp');
  const send = document.getElementById('adminChatSend');
  const qr   = document.getElementById('adminChatQR');
  const hist = [];
  let busy = false;

  function fmt(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
      .replace(/\*(.*?)\*/g,'<em>$1</em>')
      .replace(/\n/g,'<br>');
  }

  function addMsg(role, text) {
    const d = document.createElement('div');
    d.style.cssText = role === 'user'
      ? 'align-self:flex-end;background:var(--gold);color:#0d1117;padding:8px 13px;border-radius:12px 12px 3px 12px;font-size:0.84rem;max-width:85%;line-height:1.5;font-family:Poppins,sans-serif;'
      : 'align-self:flex-start;background:#151b26;border:1px solid #1f2733;color:#c5cdd8;padding:10px 14px;border-radius:12px 12px 12px 3px;font-size:0.84rem;max-width:90%;line-height:1.6;font-family:Poppins,sans-serif;';
    d.innerHTML = fmt(text);
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function showTyping() {
    const d = document.createElement('div');
    d.id = 'adminTyping';
    d.style.cssText = 'align-self:flex-start;background:#151b26;border:1px solid #1f2733;color:#6b7585;padding:10px 14px;border-radius:12px;font-size:0.8rem;font-family:Poppins,sans-serif;';
    d.innerHTML = '<i class="fa-solid fa-robot" style="color:var(--gold);margin-right:6px;"></i> Thinking...';
    msgs.appendChild(d); msgs.scrollTop = msgs.scrollHeight;
  }
  function hideTyping() { const t = document.getElementById('adminTyping'); if(t) t.remove(); }

  function setQR(items) {
    qr.innerHTML = '';
    items.forEach(item => {
      const b = document.createElement('button');
      b.textContent = item;
      b.style.cssText = 'background:transparent;border:1px solid #2a3441;color:#c5cdd8;padding:5px 12px;border-radius:20px;font-size:0.75rem;cursor:pointer;font-family:Poppins,sans-serif;';
      b.onmouseover = () => { b.style.borderColor='var(--gold)'; b.style.color='var(--gold)'; };
      b.onmouseout  = () => { b.style.borderColor='#2a3441'; b.style.color='#c5cdd8'; };
      b.onclick = () => go(item);
      qr.appendChild(b);
    });
  }

  async function go(text) {
    text = (text || inp.value).trim();
    if (!text || busy) return;
    busy = true; inp.value = ''; qr.innerHTML = '';
    addMsg('user', text); hist.push({ r:'user', t:text });
    showTyping();
    try {
      const res = await fetch('/api/admin-chat', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ message: text, history: hist.slice(-20) })
      });
      const data = await res.json();
      hideTyping();
      const reply = data.reply || 'No response.';
      addMsg('assistant', reply); hist.push({ r:'assistant', t:reply });
      setQR(['How many inquiries today?', 'Summarize pending reviews', 'Draft a puppy description', 'Show site stats']);
    } catch(e) {
      hideTyping();
      addMsg('assistant', 'Something went wrong. Please try again.');
    }
    busy = false;
  }

  // Welcome message
  setTimeout(() => {
    addMsg('assistant', 'Hi Bryan! 👋 I have full access to your site data right now. Ask me anything — puppy stats, pending reviews, customer inquiries, or I can draft descriptions and replies for you.');
    setQR(['Show site stats', 'Any pending reviews?', 'Recent inquiries', 'Draft a puppy description']);
  }, 400);

  send.addEventListener('click', () => go());
  inp.addEventListener('keydown', e => { if(e.key==='Enter' && !e.shiftKey) { e.preventDefault(); go(); } });
  inp.addEventListener('input', () => { inp.style.height='auto'; inp.style.height=Math.min(inp.scrollHeight,80)+'px'; });
})();
</script>

<%- include('partials/admin-footer') %>