<%- include('partials/admin-header', {title: 'Dashboard | Admin', active: 'dashboard', heading: 'Dashboard Overview'}) %>

<!-- Needs Your Attention -->
<% 
  var attentionItems = [];
  if (typeof pendingReviews !== 'undefined' && pendingReviews > 0) attentionItems.push({ count: pendingReviews, label: 'Review' + (pendingReviews > 1 ? 's' : '') + ' awaiting approval', href: '/admin/testimonials' });
  if (typeof pendingApplications !== 'undefined' && pendingApplications > 0) attentionItems.push({ count: pendingApplications, label: 'Application' + (pendingApplications > 1 ? 's' : '') + ' to review', href: '/admin/applications' });
  if (typeof waitlistPendingDeposit !== 'undefined' && waitlistPendingDeposit > 0) attentionItems.push({ count: waitlistPendingDeposit, label: 'Waitlist request' + (waitlistPendingDeposit > 1 ? 's' : '') + ' awaiting deposit', href: '/admin/waitlist' });
  if (typeof unpaidInvoices !== 'undefined' && unpaidInvoices > 0) attentionItems.push({ count: unpaidInvoices, label: 'Invoice' + (unpaidInvoices > 1 ? 's' : '') + ' with balance due', href: '/admin/invoices' });
%>
<div class="admin-attention">
  <div class="admin-attention-head"><i class="fa-solid fa-bell" style="color:var(--gold);"></i> Needs Your Attention</div>
  <% if (attentionItems.length === 0) { %>
    <div class="admin-attention-empty"><i class="fa-solid fa-circle-check"></i> All caught up — nothing waiting on you right now.</div>
  <% } else { %>
    <div class="admin-attention-grid">
      <% attentionItems.forEach(function(item) { %>
        <a href="<%= item.href %>" class="admin-attention-item">
          <span class="admin-attention-count"><%= item.count %></span>
          <span class="admin-attention-label"><%= item.label %></span>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>

<!-- Summary cards -->
<div class="admin-overview-grid">
  <div class="admin-overview-card card-gold">
    <div class="admin-overview-icon"><i class="fa-solid fa-heart"></i></div>
    <div>
      <span class="admin-overview-num"><%= puppies.length %></span>
      <span class="admin-overview-label">Total Puppies</span>
      <span class="admin-overview-sub">
        <span style="color:#2e9e4f;"><%= puppies.filter(p => p.status === 'Available').length %> available</span> •
        <span style="color:var(--gold);"><%= puppies.filter(p => p.status === 'Reserved').length %> reserved</span> •
        <span style="color:#8b96a8;"><%= puppies.filter(p => p.status === 'Sold').length %> sold</span>
      </span>
    </div>
  </div>

  <div class="admin-overview-card card-blue">
    <div class="admin-overview-icon"><i class="fa-solid fa-newspaper"></i></div>
    <div>
      <span class="admin-overview-num"><%= posts.length %></span>
      <span class="admin-overview-label">Blog Posts</span>
      <span class="admin-overview-sub">
        <span style="color:#2e9e4f;"><%= posts.filter(p => p.published).length %> published</span> •
        <span style="color:var(--gold);"><%= posts.filter(p => !p.published).length %> drafts</span>
      </span>
    </div>
  </div>

  <div class="admin-overview-card card-red">
    <div class="admin-overview-icon"><i class="fa-solid fa-envelope"></i></div>
    <div>
      <span class="admin-overview-num"><%= inquiries.length %></span>
      <span class="admin-overview-label">Messages</span>
      <span class="admin-overview-sub"><%= inquiries.length %> total messages received</span>
    </div>
  </div>

  <div class="admin-overview-card card-green">
    <div class="admin-overview-icon"><i class="fa-solid fa-star"></i></div>
    <div>
      <span class="admin-overview-num"><%= testimonials.length %></span>
      <span class="admin-overview-label">Testimonials</span>
      <span class="admin-overview-sub">
        Customer reviews & success stories
        <% if (typeof pendingReviews !== 'undefined' && pendingReviews > 0) { %>
          <br><a href="/admin/testimonials" style="color:var(--gold);font-weight:700;"><i class="fa-solid fa-clock"></i> <%= pendingReviews %> pending approval</a>
        <% } %>
      </span>
    </div>
  </div>
</div>

<!-- Pipeline at a glance -->
<div class="admin-stat-pills">
  <a href="/admin/litters" class="admin-stat-pill">
    <span class="admin-stat-pill-num"><%= litters.length %></span>
    <span class="admin-stat-pill-label">Litters</span>
  </a>
  <a href="/admin/applications" class="admin-stat-pill">
    <span class="admin-stat-pill-num"><%= typeof totalApplications !== 'undefined' ? totalApplications : 0 %></span>
    <span class="admin-stat-pill-label">Applications</span>
  </a>
  <a href="/admin/waitlist" class="admin-stat-pill">
    <span class="admin-stat-pill-num"><%= typeof waitlistActive !== 'undefined' ? waitlistActive : 0 %> / <%= typeof totalWaitlist !== 'undefined' ? totalWaitlist : 0 %></span>
    <span class="admin-stat-pill-label">Active Waitlist</span>
  </a>
  <a href="/admin/invoices" class="admin-stat-pill">
    <span class="admin-stat-pill-num"><%= typeof totalInvoices !== 'undefined' ? totalInvoices : 0 %></span>
    <span class="admin-stat-pill-label">Invoices</span>
  </a>
  <a href="/admin/certificates" class="admin-stat-pill">
    <span class="admin-stat-pill-num"><%= typeof totalCertificates !== 'undefined' ? totalCertificates : 0 %></span>
    <span class="admin-stat-pill-label">Certificates</span>
  </a>
</div>

<!-- Quick Actions -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-bolt" style="color:var(--gold);"></i> Quick Actions</h3>
  </div>
  <div class="admin-quick-grid">
    <a href="/admin/puppies/new" class="admin-quick-card admin-quick-primary">
      <i class="fa-solid fa-plus"></i>
      <span>Add Puppy</span>
    </a>
    <a href="/admin/posts/new" class="admin-quick-card admin-quick-outline">
      <i class="fa-solid fa-pen"></i>
      <span>New Post</span>
    </a>
    <a href="/admin/inquiries" class="admin-quick-card">
      <i class="fa-solid fa-envelope"></i>
      <span>Messages (<%= inquiries.length %>)</span>
    </a>
    <a href="/admin/testimonials/new" class="admin-quick-card">
      <i class="fa-solid fa-star"></i>
      <span>Add Review</span>
    </a>
    <a href="/admin/faqs/new" class="admin-quick-card">
      <i class="fa-solid fa-circle-question"></i>
      <span>Add FAQ</span>
    </a>
    <a href="/admin/settings" class="admin-quick-card">
      <i class="fa-solid fa-gear"></i>
      <span>Settings</span>
    </a>
  </div>
</div>

<h3 style="color:#6b7585;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;margin:32px 0 16px;font-weight:700;">Recent Activity</h3>

<!-- Recent Messages -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-envelope" style="color:var(--maroon);"></i> Recent Messages</h3>
    <a href="/admin/inquiries" class="admin-btn admin-btn-ghost">View All</a>
  </div>
  <% if (inquiries.length === 0) { %>
    <p class="admin-empty">No messages yet.</p>
  <% } else { %>
    <% inquiries.slice(0, 5).forEach(function(inq) { %>
      <div class="admin-recent-row">
        <div>
          <span class="admin-recent-title"><%= inq.name %></span>
          <span class="admin-recent-sub"><%= inq.subject %></span>
        </div>
        <div style="text-align:right;">
          <span class="admin-badge-new">NEW</span>
          <span class="admin-recent-date"><%= inq.createdAt.toLocaleDateString() %></span>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<!-- Recent Puppies -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-heart" style="color:var(--gold);"></i> Recent Puppies</h3>
    <a href="/admin/puppies" class="admin-btn admin-btn-ghost">View All</a>
  </div>
  <% if (puppies.length === 0) { %>
    <p class="admin-empty">No puppies yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Name</th><th>Status</th><th>Price</th><th>Added</th><th></th></tr></thead>
      <tbody>
        <% puppies.slice(0, 5).forEach(function(p) { %>
          <tr>
            <td>
              <span style="font-weight:600;"><%= p.name %></span><br>
              <span style="color:#8b96a8;font-size:0.82rem;"><%= p.gender %> • <%= p.color %></span>
            </td>
            <td><span class="status-badge status-<%= p.status.toLowerCase() %>"><%= p.status %></span></td>
            <td style="color:var(--maroon);font-weight:600;">$<%= p.price %></td>
            <td style="color:#8b96a8;font-size:0.85rem;"><%= p.createdAt.toLocaleDateString() %></td>
            <td class="admin-actions">
              <a href="/admin/puppies/edit/<%= p._id %>" class="admin-btn-sm"><i class="fa-solid fa-pen"></i></a>
              <a href="/admin/puppies/delete/<%= p._id %>" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Delete this puppy?')"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- Recent Blog Posts -->
<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-newspaper" style="color:#2b6cb0;"></i> Recent Blog Posts</h3>
    <a href="/admin/posts" class="admin-btn admin-btn-ghost">View All</a>
  </div>
  <% if (posts.length === 0) { %>
    <p class="admin-empty">No posts yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Status</th><th>Date</th><th></th></tr></thead>
      <tbody>
        <% posts.slice(0, 5).forEach(function(p) { %>
          <tr>
            <td><%= p.title %></td>
            <td><span class="status-badge status-available">Published</span></td>
            <td style="color:#8b96a8;font-size:0.85rem;"><%= p.createdAt.toLocaleDateString() %></td>
            <td class="admin-actions">
              <a href="/blog/<%= p.slug %>" target="_blank" class="admin-btn-sm"><i class="fa-solid fa-eye"></i></a>
              <a href="/admin/posts/edit/<%= p._id %>" class="admin-btn-sm"><i class="fa-solid fa-pen"></i></a>
              <a href="/admin/posts/delete/<%= p._id %>" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Delete this post?')"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<h3 style="color:#6b7585;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;margin:32px 0 16px;font-weight:700;">Assistant</h3>

<!-- Admin AI Assistant -->
<div class="admin-section" style="margin-top:0;">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-robot" style="color:var(--gold);"></i> AI Assistant</h3>
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="color:#8b96a8;font-size:0.8rem;">Knows everything about your site in real time</span>
      <button id="adminChatClear" title="Clear conversation" style="background:none;border:1px solid #2a3441;color:#8b96a8;padding:4px 10px;border-radius:6px;font-size:0.72rem;cursor:pointer;"><i class="fa-solid fa-trash"></i> Clear</button>
    </div>
  </div>
  <div id="adminChatMsgs" style="min-height:120px;max-height:360px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding:4px 0 12px;"></div>
  <div style="display:flex;gap:8px;margin-top:12px;align-items:flex-end;">
    <label id="adminImgBtn" title="Upload a puppy photo for AI analysis" style="width:42px;height:42px;background:#1c2430;border:1px solid #2a3441;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#c9a227;font-size:1rem;flex-shrink:0;">
      <i class="fa-solid fa-image"></i>
      <input type="file" id="adminImgInput" accept="image/*" style="display:none;">
    </label>
    <textarea id="adminChatInp" placeholder="Ask anything, or upload a photo above for AI to describe the puppy…" style="flex:1;background:#1c2430;border:1.5px solid #2a3441;color:#fff;border-radius:8px;padding:10px 12px;font-family:'Poppins',sans-serif;font-size:0.85rem;resize:none;outline:none;line-height:1.5;max-height:80px;" rows="2"></textarea>
    <button id="adminChatSend" style="background:var(--gold);color:#0d1117;border:none;border-radius:8px;width:42px;height:42px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="fa-solid fa-paper-plane"></i></button>
  </div>
  <div id="adminImgPreview" style="display:none;margin-top:8px;padding:8px 10px;background:#1c2430;border:1px solid #2a3441;border-radius:8px;align-items:center;gap:10px;">
    <img id="adminImgThumb" style="width:50px;height:50px;object-fit:cover;border-radius:6px;">
    <span style="color:#c5cdd8;font-size:0.8rem;flex:1;" id="adminImgName"></span>
    <button onclick="clearImg()" style="background:none;border:none;color:#e8848f;cursor:pointer;font-size:0.8rem;"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;" id="adminChatQR"></div>
</div>

<style>
  #adminChatMsgs, #adminChatInp, #adminChatQR button {
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    -webkit-font-smoothing: antialiased;
    letter-spacing: 0.1px;
  }
  #adminChatMsgs > div { line-height: 1.65; }
  .admin-dot {
    width: 7px; height: 7px;
    background: var(--gold);
    border-radius: 50%;
    display: inline-block;
    animation: adminDotPulse 1.1s ease-in-out infinite;
    opacity: 0.4;
  }
  .admin-dot:nth-child(2) { animation-delay: 0.15s; }
  .admin-dot:nth-child(3) { animation-delay: 0.3s; }
  @keyframes adminDotPulse {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }
</style>

<script>
(function() {
  const msgs = document.getElementById('adminChatMsgs');
  const inp  = document.getElementById('adminChatInp');
  const send = document.getElementById('adminChatSend');
  const qr   = document.getElementById('adminChatQR');
  const STORAGE_KEY = 'sbk_admin_chat_history';
  let hist = [];
  try {
    const saved = sessionStorage.getItem(STORAGE_KEY);
    if (saved) hist = JSON.parse(saved);
  } catch(e) { hist = []; }
  let busy = false;

  function saveHist() {
    try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(hist.slice(-40))); } catch(e) {}
  }

  function fmt(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
      .replace(/\*(.*?)\*/g,'<em>$1</em>')
      .replace(/\n/g,'<br>');
  }

  function addMsg(role, text) {
    const d = document.createElement('div');
    d.style.cssText = role === 'user'
      ? 'align-self:flex-end;background:var(--gold);color:#0d1117;padding:8px 13px;border-radius:12px 12px 3px 12px;font-size:0.84rem;max-width:85%;line-height:1.5;font-family:Poppins,sans-serif;'
      : 'align-self:flex-start;background:#151b26;border:1px solid #1f2733;color:#c5cdd8;padding:10px 14px;border-radius:12px 12px 12px 3px;font-size:0.84rem;max-width:90%;line-height:1.6;font-family:Poppins,sans-serif;';
    d.innerHTML = fmt(text);
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function showTyping() {
    const d = document.createElement('div');
    d.id = 'adminTyping';
    d.style.cssText = 'align-self:flex-start;background:#151b26;border:1px solid #1f2733;padding:12px 16px;border-radius:12px;display:flex;gap:4px;align-items:center;';
    d.innerHTML = '<span class="admin-dot"></span><span class="admin-dot"></span><span class="admin-dot"></span>';
    msgs.appendChild(d); msgs.scrollTop = msgs.scrollHeight;
  }
  function hideTyping() { const t = document.getElementById('adminTyping'); if(t) t.remove(); }

  function setQR(items) {
    qr.innerHTML = '';
    items.forEach(item => {
      const b = document.createElement('button');
      b.textContent = item;
      b.style.cssText = 'background:transparent;border:1px solid #2a3441;color:#c5cdd8;padding:5px 12px;border-radius:20px;font-size:0.75rem;cursor:pointer;font-family:Poppins,sans-serif;';
      b.onmouseover = () => { b.style.borderColor='var(--gold)'; b.style.color='var(--gold)'; };
      b.onmouseout  = () => { b.style.borderColor='#2a3441'; b.style.color='#c5cdd8'; };
      b.onclick = () => go(item);
      qr.appendChild(b);
    });
  }

  // Image upload handling (single image)
  let pendingImage = null;

  function clearImg() {
    pendingImage = null;
    document.getElementById('adminImgInput').value = '';
    document.getElementById('adminImgPreview').style.display = 'none';
  }

  document.getElementById('adminImgInput').addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    if (file.size > 4 * 1024 * 1024) {
      addMsg('assistant', '⚠️ Image too large — please use a photo under 4MB.');
      return;
    }
    const reader = new FileReader();
    reader.onload = function(e) {
      pendingImage = { data: e.target.result, file };
      const preview = document.getElementById('adminImgPreview');
      document.getElementById('adminImgThumb').src = e.target.result;
      document.getElementById('adminImgName').textContent = file.name + ' — ready to analyze';
      preview.style.display = 'flex';
    };
    reader.readAsDataURL(file);
  });

  async function safeJson(res) {
    const text = await res.text();
    try {
      return JSON.parse(text);
    } catch(e) {
      console.error('Non-JSON response:', text.slice(0, 200));
      return { ok: false, reply: `Server returned an unexpected response (status ${res.status}).` };
    }
  }

  async function analyzeImage(imageDataUrl, file, customPrompt) {
    const base64 = imageDataUrl.split(',')[1];
    const mimeType = file.type || 'image/jpeg';
    const res = await fetch('/api/admin-vision', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ imageData: base64, mimeType, prompt: customPrompt || null })
    });
    const data = await safeJson(res);
    return data.reply || 'No response from vision AI.';
  }

  async function executeAction(actionJson) {
    try {
      const res = await fetch('/api/admin-action', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify(actionJson)
      });
      const data = await safeJson(res);
      return data;
    } catch(e) {
      return { ok: false, message: 'Action request failed.' };
    }
  }

  async function go(text) {
    text = (text || inp.value).trim();
    const hasImage = pendingImage !== null;
    if (!text && !hasImage) return;
    if (busy) return;
    busy = true;

    const displayText = text || '📸 Analyzing this puppy photo…';
    inp.value = ''; qr.innerHTML = '';
    addMsg('user', displayText);
    hist.push({ r:'user', t:displayText }); saveHist();

    showTyping();
    try {
      let reply;

      if (hasImage) {
        const customPrompt = text || null;
        const imgData = pendingImage;
        clearImg();
        reply = await analyzeImage(imgData.data, imgData.file, customPrompt);
      } else {
        const res = await fetch('/api/admin-chat', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ message: text, history: hist.slice(-20) })
        });
        const data = await safeJson(res);
        reply = data.reply || 'No response.';
      }

      hideTyping();

      const actionRegex = /<ACTION>([\s\S]*?)<\/ACTION>/g;
      const actions = [];
      let match;
      while ((match = actionRegex.exec(reply)) !== null) {
        try { actions.push(JSON.parse(match[1])); } catch(e) {}
      }

      const displayReply = reply.replace(/<ACTION>[\s\S]*?<\/ACTION>/g, '').trim();
      if (displayReply) { addMsg('assistant', displayReply); hist.push({ r:'assistant', t:displayReply }); saveHist(); }

      for (const actionObj of actions) {
        showTyping();
        await new Promise(r => setTimeout(r, 400));
        hideTyping();
        const result = await executeAction(actionObj);
        const resultMsg = result.ok ? `✅ Done: ${result.message}` : `❌ Failed: ${result.message}`;
        addMsg('assistant', resultMsg);
        hist.push({ r:'assistant', t:resultMsg }); saveHist();
      }

      if (hasImage) {
        setQR(['Use this as a listing description', 'Give me more caption ideas', 'What breed traits do you see?', 'Make it shorter']);
      } else {
        setQR(['Show site stats', 'Any pending reviews?', 'Approve all reviews', 'Show all puppies', 'Recent inquiries']);
      }

    } catch(e) {
      hideTyping();
      addMsg('assistant', 'Something went wrong. Please try again.');
      clearImg();
    }
    busy = false;
  }

  // Restore previous conversation, or show welcome message if none
  if (hist.length > 0) {
    hist.forEach(m => addMsg(m.r === 'assistant' ? 'assistant' : 'user', m.t));
    setQR(['Show site stats', 'Any pending reviews?', 'Recent inquiries', 'Approve all reviews']);
  } else {
    setTimeout(() => {
      addMsg('assistant', 'Hi Bryan! 👋 I have full access to your site data right now. Ask me anything — puppy stats, pending reviews, customer inquiries, or upload a photo and I can draft a description and captions for you.');
      hist.push({ r:'assistant', t: 'Hi Bryan! 👋 I have full access to your site data right now. Ask me anything — puppy stats, pending reviews, customer inquiries, or upload a photo and I can draft a description and captions for you.' });
      saveHist();
      setQR(['Show site stats', 'Any pending reviews?', 'Recent inquiries', 'Approve all reviews']);
    }, 400);
  }

  send.addEventListener('click', () => go());
  inp.addEventListener('keydown', e => { if(e.key==='Enter' && !e.shiftKey) { e.preventDefault(); go(); } });
  inp.addEventListener('input', () => { inp.style.height='auto'; inp.style.height=Math.min(inp.scrollHeight,80)+'px'; });
  document.getElementById('adminChatClear').addEventListener('click', () => {
    if (!confirm('Clear this conversation?')) return;
    hist = [];
    sessionStorage.removeItem(STORAGE_KEY);
    msgs.innerHTML = '';
    qr.innerHTML = '';
    const welcome = 'Hi Bryan! 👋 I have full access to your site data right now. Ask me anything — puppy stats, pending reviews, customer inquiries, or upload a photo and I can draft a description and captions for you.';
    addMsg('assistant', welcome);
    hist.push({ r:'assistant', t: welcome });
    saveHist();
    setQR(['Show site stats', 'Any pending reviews?', 'Recent inquiries', 'Approve all reviews']);
  });
})();
</script>

<%- include('partials/admin-footer') %>