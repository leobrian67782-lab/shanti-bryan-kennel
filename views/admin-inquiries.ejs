<%- include('partials/admin-header', {title: 'Inquiries | Admin', active: 'inquiries', heading: 'Contact Inquiries'}) %>

<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-envelope" style="color:var(--maroon);"></i> Messages from your Contact form</h3>
  </div>
  <% if (inquiries.length === 0) { %>
    <p class="admin-empty">No inquiries yet.</p>
  <% } else { %>
    <div class="admin-inquiry-list">
      <% inquiries.forEach(function(inq, i) { %>
        <div class="admin-inquiry-card">
          <div class="admin-inquiry-row">
            <div class="admin-inquiry-who">
              <span class="admin-inquiry-name"><%= inq.name %></span>
              <span class="admin-inquiry-date"><%= inq.createdAt.toLocaleDateString() %></span>
            </div>
            <button type="button" class="admin-inquiry-toggle" onclick="toggleInquiry(<%= i %>, this)">
              <i class="fa-solid fa-chevron-down"></i> View Details
            </button>
          </div>
          <div class="admin-inquiry-details" id="inquiry-details-<%= i %>">
            <div class="admin-inquiry-detail-row">
              <span>Email</span>
              <a href="mailto:<%= inq.email %>"><%= inq.email %></a>
            </div>
            <% if (inq.phone) { %>
              <div class="admin-inquiry-detail-row">
                <span>Phone</span>
                <a href="tel:<%= inq.phone %>"><%= inq.phone %></a>
              </div>
            <% } %>
            <div class="admin-inquiry-detail-row">
              <span>Location</span>
              <span>
                <% if (inq.location) { %><%= inq.location %><% } %>
                <% if (inq.detectedLocation) { %> <span style="color:#6b7585;">(auto: <%= inq.detectedLocation %>)</span><% } %>
                <% if (!inq.location && !inq.detectedLocation) { %>—<% } %>
              </span>
            </div>
            <div class="admin-inquiry-detail-row">
              <span>Subject</span>
              <span><%= inq.subject %></span>
            </div>
            <div class="admin-inquiry-detail-row admin-inquiry-message">
              <span>Message</span>
              <p><%= inq.message %></p>
            </div>
            <div class="admin-inquiry-delete">
              <a href="/admin/inquiries/delete/<%= inq._id %>" class="admin-btn admin-btn-danger" onclick="return confirm('Delete this inquiry?')"><i class="fa-solid fa-trash"></i> Delete</a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  function toggleInquiry(i, btn) {
    var details = document.getElementById('inquiry-details-' + i);
    var isOpen = details.classList.toggle('open');
    btn.classList.toggle('is-open', isOpen);
    btn.innerHTML = isOpen
      ? '<i class="fa-solid fa-chevron-up"></i> Hide Details'
      : '<i class="fa-solid fa-chevron-down"></i> View Details';
  }
</script>

<%- include('partials/admin-footer') %>
