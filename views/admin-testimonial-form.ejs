<%- include('partials/admin-header', {title: 'Testimonial Form | Admin', active: 'testimonial', heading: testimonial ? 'Edit Testimonial' : 'Add New Testimonial'}) %>

<div class="admin-section" style="max-width:640px;">
  <form method="POST" action="<%= testimonial ? '/admin/testimonials/edit/' + testimonial._id : '/admin/testimonials/new' %>" enctype="multipart/form-data">

    <div class="form-group">
      <label>Customer Name *</label>
      <input type="text" name="customerName" value="<%= testimonial ? testimonial.customerName : '' %>" required>
    </div>

    <div class="form-group">
      <label>Location</label>
      <input type="text" name="location" value="<%= testimonial ? testimonial.location : '' %>" placeholder="e.g. Texas">
    </div>

    <div class="form-group">
      <label>Tag</label>
      <input type="text" name="tag" value="<%= testimonial ? testimonial.tag : '' %>" placeholder="e.g. Owner of Molly">
    </div>

    <div class="form-group">
      <label>Rating *</label>
      <select name="rating" required>
        <option value="5" <%= testimonial && testimonial.rating === 5 ? 'selected' : '' %>>5 Stars</option>
        <option value="4" <%= testimonial && testimonial.rating === 4 ? 'selected' : '' %>>4 Stars</option>
        <option value="3" <%= testimonial && testimonial.rating === 3 ? 'selected' : '' %>>3 Stars</option>
        <option value="2" <%= testimonial && testimonial.rating === 2 ? 'selected' : '' %>>2 Stars</option>
        <option value="1" <%= testimonial && testimonial.rating === 1 ? 'selected' : '' %>>1 Star</option>
      </select>
    </div>

    <div class="form-group">
      <label>Message *</label>
      <textarea name="message" required><%= testimonial ? testimonial.message : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Customer Photo (optional)</label>
      <% if (testimonial && testimonial.photo) { %>
        <div style="margin-bottom:12px;">
          <img src="<%= testimonial.photo %>" style="width:100px;height:100px;object-fit:cover;border-radius:8px;display:block;margin-bottom:8px;">
          <label style="display:flex;align-items:center;gap:8px;color:#dc2626;font-weight:600;font-size:0.85rem;cursor:pointer;">
            <input type="checkbox" name="deletePhoto" value="yes" style="width:auto;margin:0;accent-color:#c0392b;">
            <i class="fa-solid fa-trash"></i> Remove this photo
          </label>
          <small style="color:#6b7280;display:block;margin-top:6px;">Or upload a new photo below to replace it automatically.</small>
        </div>
      <% } %>
      <input type="file" name="photo" accept="image/*">
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-floppy-disk"></i> <%= testimonial ? 'Update Testimonial' : 'Add Testimonial' %></button>
  </form>
</div>

<%- include('partials/admin-footer') %>
