<%- include('partials/header', {title: litter.litterName + ' | Shanti & Bryan Pinscher Kennel'}) %>

<section class="page-section">
  <div class="container" style="max-width: 950px;">
    <div class="detail-grid">
      <div>
        <% if (litter.photos && litter.photos.length > 0) { %>
          <img src="<%= litter.photos[0] %>" alt="<%= litter.litterName %>" style="width: 100%; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.1);">
        <% } else { %>
          <div style="width:100%;height:300px;background:#eee;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#999;">No photo</div>
        <% } %>
      </div>
      <div>
        <h1 class="detail-name"><%= litter.litterName %></h1>
        <div class="detail-specs">
          <div class="detail-spec-row">
            <span class="detail-spec-label">Birth Date</span>
            <span class="detail-spec-value"><%= litter.birthDate.toDateString() %></span>
          </div>
          <% if (litter.numberOfPuppies) { %>
            <div class="detail-spec-row">
              <span class="detail-spec-label">Number of Puppies</span>
              <span class="detail-spec-value"><%= litter.numberOfPuppies %></span>
            </div>
          <% } %>
        </div>
        <a href="/contact" class="btn" style="margin-top: 8px;">Inquire About This Litter</a>
      </div>
    </div>

    <% if (litter.description) { %>
      <div class="detail-about">
        <h2>About This Litter</h2>
        <p><%= litter.description %></p>
      </div>
    <% } %>

    <!-- Bloodline -->
    <div style="margin-top: 50px;">
      <h2 style="font-size: 1.8rem; text-align:center; margin-bottom: 30px;">The Parents</h2>
      <div class="bloodline-grid">

        <div class="parent-card">
          <% if (litter.sirePhoto) { %>
            <img src="<%= litter.sirePhoto %>" alt="<%= litter.sireName %>">
          <% } %>
          <div class="parent-body">
            <span class="parent-label">Sire (Father)</span>
            <h3><%= litter.sireName %></h3>
            <% if (litter.sireWeight) { %><p><strong>Weight:</strong> <%= litter.sireWeight %></p><% } %>
            <% if (litter.sireRegistration) { %><p><strong>Registration:</strong> <%= litter.sireRegistration %></p><% } %>
            <% if (litter.sireAwards) { %><p><strong>Awards:</strong> <%= litter.sireAwards %></p><% } %>
          </div>
        </div>

        <div class="parent-card">
          <% if (litter.damPhoto) { %>
            <img src="<%= litter.damPhoto %>" alt="<%= litter.damName %>">
          <% } %>
          <div class="parent-body">
            <span class="parent-label">Dam (Mother)</span>
            <h3><%= litter.damName %></h3>
            <% if (litter.damWeight) { %><p><strong>Weight:</strong> <%= litter.damWeight %></p><% } %>
            <% if (litter.damRegistration) { %><p><strong>Registration:</strong> <%= litter.damRegistration %></p><% } %>
            <% if (litter.damAwards) { %><p><strong>Awards:</strong> <%= litter.damAwards %></p><% } %>
          </div>
        </div>

      </div>
    </div>

    <div class="detail-back">
      <a href="/litters" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Back to All Litters</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
