<%- include('partials/admin-header', {title: 'Waitlist | Admin', active: 'waitlist', heading: 'Puppy Waitlist'}) %>

<div class="admin-board">

  <div class="admin-board-col col-gold">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Awaiting Deposit</span>
      <span class="admin-board-col-count"><%= pending.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (pending.length === 0) { %>
        <div class="admin-board-empty">Nothing waiting on a deposit.</div>
      <% } %>
      <% pending.forEach(function(w) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= w.name %></div>
          <div class="admin-board-card-sub"><%= w.preferredGender %>, <%= w.preferredColor %></div>
          <div class="admin-board-card-meta"><%= w.email %></div>
          <div class="admin-board-card-actions">
            <a href="/admin/waitlist/<%= w._id %>/deposit-invoice/new" class="admin-board-btn admin-board-btn-primary"><i class="fa-solid fa-receipt"></i> Record Deposit</a>
            <a href="/admin/waitlist/<%= w._id %>/cancel" class="admin-board-btn admin-board-btn-danger" onclick="return confirm('Remove this waitlist request?')"><i class="fa-solid fa-trash"></i></a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="admin-board-col col-blue">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Active</span>
      <span class="admin-board-col-count"><%= active.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (active.length === 0) { %>
        <div class="admin-board-empty">No active waitlist entries.</div>
      <% } %>
      <% active.forEach(function(w) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= w.name %></div>
          <div class="admin-board-card-sub"><%= w.preferredGender %>, <%= w.preferredColor %></div>
          <div class="admin-board-card-meta">Deposit paid: $<%= w.depositAmount %></div>
          <div class="admin-board-card-actions">
            <a href="/admin/waitlist/<%= w._id %>/matched" class="admin-board-btn admin-board-btn-primary"><i class="fa-solid fa-heart"></i> Mark Matched</a>
            <a href="/admin/waitlist/<%= w._id %>/cancel" class="admin-board-btn admin-board-btn-danger" onclick="return confirm('Cancel this entry?')"><i class="fa-solid fa-trash"></i></a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="admin-board-col col-gold">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Matched</span>
      <span class="admin-board-col-count"><%= matched.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (matched.length === 0) { %>
        <div class="admin-board-empty">No one matched yet.</div>
      <% } %>
      <% matched.forEach(function(w) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= w.name %></div>
          <div class="admin-board-card-sub"><%= w.preferredGender %>, <%= w.preferredColor %></div>
          <div class="admin-board-card-meta">Deposit paid: $<%= w.depositAmount %></div>
          <div class="admin-board-card-actions">
            <a href="/admin/waitlist/<%= w._id %>/fulfilled" class="admin-board-btn admin-board-btn-primary"><i class="fa-solid fa-check"></i> Mark Fulfilled</a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="admin-board-col col-green">
    <div class="admin-board-col-head">
      <span class="admin-board-col-title">Fulfilled</span>
      <span class="admin-board-col-count"><%= fulfilled.length %></span>
    </div>
    <div class="admin-board-cards">
      <% if (fulfilled.length === 0) { %>
        <div class="admin-board-empty">None completed yet.</div>
      <% } %>
      <% fulfilled.forEach(function(w) { %>
        <div class="admin-board-card">
          <div class="admin-board-card-name"><%= w.name %></div>
          <div class="admin-board-card-sub"><%= w.preferredGender %>, <%= w.preferredColor %></div>
          <div class="admin-board-card-meta">Completed</div>
        </div>
      <% }); %>
    </div>
  </div>

</div>

<%- include('partials/admin-footer') %>
