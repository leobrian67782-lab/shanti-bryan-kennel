<%- include('partials/admin-header', {title: 'Waitlist | Admin', active: 'waitlist', heading: 'Puppy Waitlist'}) %>

<% if (typeof pending !== 'undefined' && pending.length > 0) { %>
<div class="admin-section" style="border:1px solid #c9a22740;margin-bottom:24px;">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-clock" style="color:var(--gold);"></i> Awaiting Deposit <span style="background:var(--gold);color:#0d1117;font-size:0.75rem;font-weight:700;padding:2px 10px;border-radius:20px;margin-left:8px;"><%= pending.length %></span></h3>
  </div>
  <% pending.forEach(function(w) { %>
    <div style="border-bottom:1px solid #1f2733;padding:16px 0;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
        <div style="flex:1;min-width:0;">
          <span style="font-weight:600;color:#fff;"><%= w.name %></span>
          <span style="color:#8b96a8;font-size:0.85rem;"> — <%= w.email %><% if (w.phone) { %> · <%= w.phone %><% } %></span>
          <br>
          <span style="color:#8b96a8;font-size:0.85rem;">Wants: <%= w.preferredGender %>, <%= w.preferredColor %><% if (w.location) { %> · <%= w.location %><% } %><% if (w.detectedLocation) { %> <span style="color:#8b96a8;">(auto: <%= w.detectedLocation %>)</span><% } %></span>
          <% if (w.notes) { %><p style="color:#8b96a8;font-size:0.82rem;margin:6px 0 0;">"<%= w.notes %>"</p><% } %>
          <small style="color:#8b96a8;">Requested <%= w.createdAt.toLocaleDateString() %></small>
        </div>
        <div style="display:flex;gap:8px;flex-shrink:0;">
          <a href="/admin/waitlist/<%= w._id %>/deposit-invoice/new" class="admin-btn" style="background:var(--gold);color:#0d1117;"><i class="fa-solid fa-receipt"></i> Record Deposit</a>
          <a href="/admin/waitlist/<%= w._id %>/cancel" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Remove this waitlist request?')"><i class="fa-solid fa-trash"></i></a>
        </div>
      </div>
    </div>
  <% }); %>
</div>
<% } %>

<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-list-check" style="color:#2e9e4f;"></i> Active Waitlist <span style="color:#8b96a8;font-size:0.8rem;font-weight:400;">(deposit paid, ready to be matched)</span></h3>
  </div>
  <% if (active.length === 0) { %>
    <p class="admin-empty">No one is on the active waitlist yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>#</th><th>Name</th><th>Preferences</th><th>Deposit</th><th>Status</th><th>Since</th><th></th></tr></thead>
      <tbody>
        <% active.forEach(function(w, i) { %>
          <tr>
            <td style="font-weight:700;color:var(--gold);"><%= i + 1 %></td>
            <td><strong><%= w.name %></strong><br><span style="color:#8b96a8;font-size:0.8rem;"><%= w.email %></span></td>
            <td style="color:#8b96a8;font-size:0.85rem;"><%= w.preferredGender %>, <%= w.preferredColor %></td>
            <td style="font-weight:600;color:#2e9e4f;">$<%= w.depositAmount %> ✓</td>
            <td>
              <span style="background:<%= w.status === 'Matched' ? '#2b6cb0' : w.status === 'Fulfilled' ? '#2e9e4f' : '#8b96a8' %>;color:#fff;padding:3px 10px;border-radius:20px;font-size:0.75rem;font-weight:700;"><%= w.status %></span>
            </td>
            <td style="color:#8b96a8;font-size:0.82rem;"><%= w.createdAt.toLocaleDateString() %></td>
            <td class="admin-actions">
              <% if (w.status === 'Active') { %>
                <a href="/admin/waitlist/<%= w._id %>/matched" class="admin-btn-sm" title="Mark as Matched to a puppy"><i class="fa-solid fa-heart"></i></a>
              <% } %>
              <% if (w.status !== 'Fulfilled') { %>
                <a href="/admin/waitlist/<%= w._id %>/fulfilled" class="admin-btn-sm" title="Mark Fulfilled (puppy placed)"><i class="fa-solid fa-check"></i></a>
              <% } %>
              <a href="/admin/waitlist/<%= w._id %>/cancel" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Remove this entry?')"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('partials/admin-footer') %>
