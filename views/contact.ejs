<%- include('partials/header', {title: 'Contact Us | Shanti & Bryan Pinscher Kennel'}) %>

<section class="page-section">
  <p class="section-label">Get In Touch</p>
  <h1>Contact Us</h1>
  <div class="section-underline"></div>
  <p style="margin-top:20px;">Have questions about available puppies or upcoming litters? We'd love to hear from you!</p>

  <!-- Contact info cards -->
  <div class="contact-info-grid">
    <% if (settings && settings.email) { %>
      <a href="mailto:<%= settings.email %>" class="contact-info-card">
        <i class="fa-solid fa-envelope"></i>
        <div>
          <span class="contact-info-label">Email Us</span>
          <span class="contact-info-value"><%= settings.email %></span>
        </div>
      </a>
    <% } %>
    <% if (settings && settings.phone) { %>
      <a href="tel:<%= settings.phone %>" class="contact-info-card">
        <i class="fa-solid fa-phone"></i>
        <div>
          <span class="contact-info-label">Call Us</span>
          <span class="contact-info-value"><%= settings.phone %></span>
        </div>
      </a>
    <% } %>
  </div>

  <form method="POST" action="/contact" class="contact-form">
    <% if (message) { %>
      <div class="form-success"><%= message %></div>
    <% } %>

    <div class="form-group">
      <label for="name">Your Name *</label>
      <input type="text" id="name" name="name" required>
    </div>

    <div class="form-group">
      <label for="email">Email Address *</label>
      <input type="email" id="email" name="email" required>
    </div>

    <div class="form-group">
      <label for="phone">Phone Number</label>
      <input type="tel" id="phone" name="phone">
    </div>
    <div class="form-group">
      <label for="location">Your Location (City / Country)</label>
      <input type="text" id="location" name="location" placeholder="e.g., Dallas, Texas, USA">
    </div>

    <div class="form-group">
      <label for="subject">Subject *</label>
      <input type="text" id="subject" name="subject" placeholder="e.g., Inquiry about available puppies" required>
    </div>

    <div class="form-group">
      <label for="message">Message *</label>
      <textarea id="message" name="message" required></textarea>
    </div>

    <button type="submit" class="form-submit"><i class="fa-solid fa-paper-plane"></i> Send Message</button>
  </form>
</section>

<%- include('partials/footer') %>