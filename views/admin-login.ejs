<%- include('partials/header', {title: 'Admin Login | Shanti & Bryan Pinscher Kennel'}) %>

<section class="page-section">
  <h1>Admin Login</h1>
  <form method="POST" action="/admin/login" class="contact-form">
    <% if (error) { %>
      <div class="form-success" style="background:#f8d7da;color:#721c24;border-color:#f5c6cb;"><%= error %></div>
    <% } %>
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" required>
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
    </div>
    <button type="submit" class="form-submit">Log In</button>
  </form>
</section>

<%- include('partials/footer') %>