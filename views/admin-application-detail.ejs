<%- include('partials/admin-header', {title: 'Application Detail | Admin', active: 'applications', heading: 'Application Details'}) %>

<div class="admin-section" style="max-width:720px;">

  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
    <div>
      <h3 style="margin:0;"><%= app.applicantName %></h3>
      <p style="color:#6b7280;margin:4px 0 0;font-size:0.85rem;">Applied <%= app.createdAt.toLocaleDateString() %></p>
    </div>
    <span style="background:<%= app.status === 'Approved' ? '#2e9e4f' : app.status === 'Declined' ? '#c0392b' : '#6b7280' %>;color:#fff;padding:6px 16px;border-radius:20px;font-size:0.85rem;font-weight:700;"><%= app.status %></span>
  </div>

  <div style="display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;">
    <% if (app.status !== 'Approved') { %>
      <a href="/admin/applications/<%= app._id %>/approve" class="admin-btn" style="background:#2e9e4f;"><i class="fa-solid fa-check"></i> Approve</a>
    <% } %>
    <% if (app.status !== 'Declined') { %>
      <a href="/admin/applications/<%= app._id %>/decline" class="admin-btn admin-btn-danger" onclick="return confirm('Decline this application?')"><i class="fa-solid fa-xmark"></i> Decline</a>
    <% } %>
    <a href="/admin/invoices/new" class="admin-btn" style="background:var(--gold);color:var(--navy);"><i class="fa-solid fa-file-invoice-dollar"></i> Create Invoice</a>
    <a href="mailto:<%= app.email %>" class="admin-btn-sm" style="padding:10px 16px;"><i class="fa-solid fa-envelope"></i> Email</a>
  </div>

  <div style="background:#ffffff;border:1px solid #e5e7eb;border-radius:10px;padding:20px 24px;">

    <h4 style="color:var(--gold);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Contact Info</h4>
    <div class="admin-form-grid-2" style="margin-bottom:24px;font-size:0.9rem;">
      <div><span style="color:#6b7280;">Email:</span> <span style="color:#111827;"><%= app.email %></span></div>
      <div><span style="color:#6b7280;">Phone:</span> <span style="color:#111827;"><%= app.phone || '—' %></span></div>
      <div><span style="color:#6b7280;">Location:</span> <span style="color:#111827;"><%= app.location || '—' %></span><% if (app.detectedLocation) { %> <span style="color:#6b7280;font-size:0.8rem;">(auto: <%= app.detectedLocation %>)</span><% } %></div>
      <div><span style="color:#6b7280;">Interested in:</span> <span style="color:#111827;"><%= app.interestedIn %></span></div>
    </div>

    <h4 style="color:var(--gold);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Home Situation</h4>
    <div style="font-size:0.9rem;line-height:1.9;margin-bottom:24px;">
      <p><span style="color:#6b7280;">Home ownership:</span> <span style="color:#111827;"><%= app.homeOwnership || '—' %></span></p>
      <p><span style="color:#6b7280;">Landlord approval:</span> <span style="color:#111827;"><%= app.landlordApproval || '—' %></span></p>
      <p><span style="color:#6b7280;">Yard / exercise plan:</span> <span style="color:#111827;"><%= app.yardOrExercise || '—' %></span></p>
      <p><span style="color:#6b7280;">Other pets:</span> <span style="color:#111827;"><%= app.otherPets || '—' %></span></p>
      <p><span style="color:#6b7280;">Children in home:</span> <span style="color:#111827;"><%= app.childrenInHome || '—' %></span></p>
    </div>

    <h4 style="color:var(--gold);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Experience & Motivation</h4>
    <div style="font-size:0.9rem;line-height:1.9;margin-bottom:24px;">
      <p><span style="color:#6b7280;">Previous experience:</span> <span style="color:#111827;"><%= app.previousExperience || '—' %></span></p>
      <p><span style="color:#6b7280;">Primary caretaker:</span> <span style="color:#111827;"><%= app.primaryCaretaker || '—' %></span></p>
      <p><span style="color:#6b7280;">Why a Min Pin:</span> <span style="color:#111827;"><%= app.whyMinPin || '—' %></span></p>
      <p><span style="color:#6b7280;">Ready for responsibility:</span> <span style="color:#111827;"><%= app.readyForResponsibility ? '✅ Yes, confirmed' : '❌ Not confirmed' %></span></p>
    </div>

  </div>

  <a href="/admin/applications" style="display:inline-block;margin-top:20px;color:#6b7280;font-size:0.85rem;"><i class="fa-solid fa-arrow-left"></i> Back to all applications</a>
</div>

<%- include('partials/admin-footer') %>
