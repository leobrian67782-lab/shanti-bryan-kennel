<%- include('partials/admin-header', {title: 'Application Detail | Admin', active: 'applications', heading: 'Application Details'}) %>

<div class="admin-section" style="max-width:720px;">

  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
    <div>
      <h3 style="margin:0;"><%= app.applicantName %></h3>
      <p style="color:var(--text-light);margin:4px 0 0;font-size:0.85rem;">Applied <%= app.createdAt.toLocaleDateString() %></p>
    </div>
    <span style="background:<%= app.status === 'Approved' ? '#2e9e4f' : app.status === 'Declined' ? '#c0392b' : '#6b7585' %>;color:#fff;padding:6px 16px;border-radius:20px;font-size:0.85rem;font-weight:700;"><%= app.status %></span>
  </div>

  <div style="display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;">
    <% if (app.status !== 'Approved') { %>
      <a href="/admin/applications/<%= app._id %>/approve" class="admin-btn" style="background:#2e9e4f;"><i class="fa-solid fa-check"></i> Approve</a>
    <% } %>
    <% if (app.status !== 'Declined') { %>
      <a href="/admin/applications/<%= app._id %>/decline" class="admin-btn admin-btn-danger" onclick="return confirm('Decline this application?')"><i class="fa-solid fa-xmark"></i> Decline</a>
    <% } %>
    <a href="/admin/invoices/new" class="admin-btn" style="background:var(--gold);color:#0d1117;"><i class="fa-solid fa-file-invoice-dollar"></i> Create Invoice</a>
    <a href="mailto:<%= app.email %>" class="admin-btn-sm" style="padding:10px 16px;"><i class="fa-solid fa-envelope"></i> Email</a>
  </div>

  <div style="background:#151b26;border:1px solid #1f2733;border-radius:10px;padding:20px 24px;">

    <h4 style="color:var(--gold);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Contact Info</h4>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;font-size:0.9rem;">
      <div><span style="color:#6b7585;">Email:</span> <%= app.email %></div>
      <div><span style="color:#6b7585;">Phone:</span> <%= app.phone || '—' %></div>
      <div><span style="color:#6b7585;">Location:</span> <%= app.location || '—' %></div>
      <div><span style="color:#6b7585;">Interested in:</span> <%= app.interestedIn %></div>
    </div>

    <h4 style="color:var(--gold);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Home Situation</h4>
    <div style="font-size:0.9rem;line-height:1.9;margin-bottom:24px;">
      <p><span style="color:#6b7585;">Home ownership:</span> <%= app.homeOwnership || '—' %></p>
      <p><span style="color:#6b7585;">Landlord approval:</span> <%= app.landlordApproval || '—' %></p>
      <p><span style="color:#6b7585;">Yard / exercise plan:</span> <%= app.yardOrExercise || '—' %></p>
      <p><span style="color:#6b7585;">Other pets:</span> <%= app.otherPets || '—' %></p>
      <p><span style="color:#6b7585;">Children in home:</span> <%= app.childrenInHome || '—' %></p>
    </div>

    <h4 style="color:var(--gold);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Experience & Motivation</h4>
    <div style="font-size:0.9rem;line-height:1.9;margin-bottom:24px;">
      <p><span style="color:#6b7585;">Previous experience:</span> <%= app.previousExperience || '—' %></p>
      <p><span style="color:#6b7585;">Primary caretaker:</span> <%= app.primaryCaretaker || '—' %></p>
      <p><span style="color:#6b7585;">Why a Min Pin:</span> <%= app.whyMinPin || '—' %></p>
      <p><span style="color:#6b7585;">Ready for responsibility:</span> <%= app.readyForResponsibility ? '✅ Yes, confirmed' : '❌ Not confirmed' %></p>
    </div>

  </div>

  <a href="/admin/applications" style="display:inline-block;margin-top:20px;color:var(--text-light);font-size:0.85rem;"><i class="fa-solid fa-arrow-left"></i> Back to all applications</a>
</div>

<%- include('partials/admin-footer') %>
