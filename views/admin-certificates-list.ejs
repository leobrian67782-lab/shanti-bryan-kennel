<%- include('partials/admin-header', {title: 'Certificates | Admin', active: 'certificate', heading: 'Ownership Certificates'}) %>

<div class="admin-section">
  <div class="admin-section-head">
    <h3><i class="fa-solid fa-certificate" style="color:var(--gold);"></i> All Certificates</h3>
    <a href="/admin/certificates/new" class="admin-btn"><i class="fa-solid fa-plus"></i> New Certificate</a>
  </div>
  <% if (certificates.length === 0) { %>
    <p class="admin-empty">No certificates yet. Generate one when a puppy ownership is transferred.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Cert #</th><th>Puppy</th><th>New Owner</th><th>Transfer Date</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% certificates.forEach(function(c) { %>
          <tr>
            <td style="font-weight:700;color:var(--gold);"><%= c.certificateNumber %></td>
            <td><strong><%= c.puppyName %></strong><br><span style="color:#6b7280;font-size:0.8rem;"><%= c.puppyBreed %> · <%= c.puppyColor %></span></td>
            <td><strong><%= c.buyerName %></strong><br><span style="color:#6b7280;font-size:0.8rem;"><%= c.buyerEmail %></span></td>
            <td style="color:#6b7280;font-size:0.82rem;"><%= new Date(c.transferDate).toLocaleDateString() %></td>
            <td><span style="background:<%= c.status==='Sent'?'#2b6cb0':'#6b7280' %>;color:#fff;padding:3px 10px;border-radius:20px;font-size:0.75rem;font-weight:700;"><%= c.status %></span></td>
            <td class="admin-actions">
              <a href="/admin/certificates/<%= c._id %>/pdf" class="admin-btn-sm" title="Download PDF" target="_blank"><i class="fa-solid fa-file-pdf"></i></a>
              <a href="/admin/certificates/<%= c._id %>/send" class="admin-btn-sm" title="Resend Email" onclick="return confirm('Resend certificate to <%= c.buyerEmail %>?')"><i class="fa-solid fa-paper-plane"></i></a>
              <a href="/admin/certificates/<%= c._id %>/delete" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Delete this certificate?')"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('partials/admin-footer') %>
