<%- include('partials/header', {title: 'Puppy Application | Shanti & Bryan Pinscher Kennel', description: 'Apply to adopt a Miniature Pinscher puppy from Shanti & Bryan Pinscher Kennel.'}) %>

<section class="page-section">
  <div class="container" style="max-width:680px;">

    <div style="text-align:center;margin-bottom:36px;">
      <p class="section-label">Join Our Family</p>
      <h1 class="section-title">Puppy Application</h1>
      <div class="section-divider"></div>
      <p style="color:var(--text-light);margin-top:16px;">We care deeply about where our puppies go. Please take a few minutes to tell us about your home and family — this helps us match you with the right companion.</p>
    </div>

    <% if (sent) { %>
      <div class="form-success" style="text-align:center;padding:32px;font-size:1.05rem;">
        <i class="fa-solid fa-circle-check" style="font-size:2rem;display:block;margin-bottom:12px;"></i>
        <strong>Application received!</strong><br>
        <span style="font-size:0.95rem;color:#155724;">Thank you for applying. We review every application personally and will reach out within 2-3 days.</span>
      </div>
    <% } else { %>

      <% if (error) { %>
        <div class="form-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
      <% } %>

      <form method="POST" action="/apply" class="contact-form">

        <h3 style="color:var(--navy);margin-bottom:16px;font-size:1.05rem;">About You</h3>

        <div class="form-group">
          <label>Full Name *</label>
          <input type="text" name="applicantName" required>
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" required>
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="text" name="phone">
        </div>
        <div class="form-group">
          <label>Location (City, State/Country)</label>
          <input type="text" name="location">
        </div>

        <div class="form-group">
          <label>Which puppy are you interested in?</label>
          <select name="interestedIn">
            <option value="General / Future Litter">General interest / future litter</option>
            <% puppies.forEach(function(p) { %>
              <option value="<%= p.name %> (<%= p.gender %>, <%= p.color %>)"><%= p.name %> — <%= p.gender %>, <%= p.color %> (<%= p.status %>)</option>
            <% }); %>
          </select>
        </div>

        <h3 style="color:var(--navy);margin:28px 0 16px;font-size:1.05rem;">Your Home</h3>

        <div class="form-group">
          <label>Do you own or rent your home? *</label>
          <select name="homeOwnership" required>
            <option value="">Select one</option>
            <option value="Own">Own</option>
            <option value="Rent">Rent</option>
          </select>
        </div>
        <div class="form-group">
          <label>If renting, does your landlord approve of pets?</label>
          <select name="landlordApproval">
            <option value="N/A">Not applicable — I own my home</option>
            <option value="Yes">Yes, approved</option>
            <option value="No">Not yet confirmed</option>
          </select>
        </div>
        <div class="form-group">
          <label>Do you have a yard, or how will the puppy get daily exercise? *</label>
          <textarea name="yardOrExercise" rows="2" required></textarea>
        </div>
        <div class="form-group">
          <label>Do you currently have other pets? If so, what kind?</label>
          <input type="text" name="otherPets" placeholder="e.g. One cat, no other dogs">
        </div>
        <div class="form-group">
          <label>Are there children in the home? What ages?</label>
          <input type="text" name="childrenInHome" placeholder="e.g. No children / Two kids, ages 8 and 11">
        </div>

        <h3 style="color:var(--navy);margin:28px 0 16px;font-size:1.05rem;">Your Experience</h3>

        <div class="form-group">
          <label>Have you owned a Miniature Pinscher or similar breed before?</label>
          <textarea name="previousExperience" rows="2" placeholder="Tell us about any past experience with dogs"></textarea>
        </div>
        <div class="form-group">
          <label>Who will be the primary caretaker of the puppy? *</label>
          <input type="text" name="primaryCaretaker" required>
        </div>
        <div class="form-group">
          <label>Why are you interested in a Miniature Pinscher specifically? *</label>
          <textarea name="whyMinPin" rows="3" required></textarea>
        </div>

        <div class="form-group">
          <label style="display:flex;align-items:flex-start;gap:10px;font-weight:400;cursor:pointer;">
            <input type="checkbox" name="readyForResponsibility" value="yes" required style="width:auto;margin-top:4px;">
            <span>I understand and am prepared for the financial and time responsibility of raising a dog, including food, veterinary care, training, and daily attention for the lifetime of the pet. *</span>
          </label>
        </div>

        <button type="submit" class="form-submit"><i class="fa-solid fa-paper-plane"></i> Submit Application</button>
      </form>

    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
