<%- include('partials/header', {title: 'Available Puppies | Shanti & Bryan Pinscher Kennel'}) %>

<section class="page-section">
  <p class="section-label">Find Your Perfect Companion</p>
  <h1>Available Puppies</h1>
  <div class="section-underline"></div>
  <p style="margin-top:20px;">Meet our adorable Miniature Pinscher puppies looking for their forever homes. Each one comes with full vet records, vaccinations, and our written 1-year health guarantee.</p>

  <div style="background:#faf7f0;border:1px solid #ece5d8;border-radius:10px;padding:14px 20px;margin-top:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <span style="color:var(--text-light);font-size:0.9rem;"><i class="fa-solid fa-heart" style="color:var(--gold);"></i> Don't see the perfect match? Join our waitlist for the next litter.</span>
    <a href="/waitlist" class="btn btn-gold" style="padding:8px 20px;font-size:0.85rem;">Join Waitlist</a>
  </div>

  <% if (puppies.length === 0) { %>
    <p style="margin-top:40px;">No puppies listed right now. Check back soon, or <a href="/waitlist" style="color:var(--maroon);font-weight:600;">join our waitlist</a> to be notified about our next litter.</p>
  <% } else { %>
    <div class="puppy-filter-panel">
      <div class="puppy-filter-header">
        <span><i class="fa-solid fa-sliders"></i> Filter Puppies</span>
        <button type="button" id="clearFiltersBtn" class="filter-clear-link" style="display:none;">Clear Filters</button>
      </div>
      <div class="puppy-filter-row">
        <div class="filter-segment-group" data-filter-type="gender">
          <span class="filter-segment-label">Gender</span>
          <div class="filter-segment">
            <button type="button" class="seg-btn active" data-value="all">All</button>
            <button type="button" class="seg-btn" data-value="male">Male</button>
            <button type="button" class="seg-btn" data-value="female">Female</button>
          </div>
        </div>
        <div class="filter-segment-group" data-filter-type="status">
          <span class="filter-segment-label">Status</span>
          <div class="filter-segment">
            <button type="button" class="seg-btn active" data-value="all">All</button>
            <button type="button" class="seg-btn" data-value="available">Available</button>
            <button type="button" class="seg-btn" data-value="reserved">Reserved</button>
            <button type="button" class="seg-btn" data-value="sold">Sold</button>
          </div>
        </div>
      </div>
    </div>

    <p id="filterEmptyMsg" style="display:none;margin-top:40px;color:var(--text-light);">No puppies match these filters right now. Try adjusting your selection above, or <a href="/waitlist" style="color:var(--maroon);font-weight:600;">join our waitlist</a>.</p>

    <div class="card-grid" id="puppyGrid">
      <% puppies.forEach(function(puppy) { %>
        <a href="/puppies/<%= puppy._id %>" class="puppy-card-link" data-gender="<%= puppy.gender.toLowerCase() %>" data-status="<%= puppy.status.toLowerCase() %>" style="text-decoration:none;color:inherit;">
          <div class="card">
            <% if (puppy.photos && puppy.photos.length > 0) { %>
              <div style="position:relative;">
                <img src="<%= puppy.photos[0] %>" alt="<%= puppy.name %>">
                <span class="status-badge status-<%= puppy.status.toLowerCase() %>" style="position:absolute;top:14px;left:14px;"><%= puppy.status %></span>
              </div>
            <% } %>
            <div class="card-body">
              <h3><%= puppy.name %></h3>
              <div class="info-pills">
                <span class="info-pill"><%= puppy.gender %></span>
                <span class="info-pill"><%= puppy.color %></span>
              </div>
              <% if (puppy.description) { %>
                <p class="card-desc"><%= puppy.description.substring(0, 70) %><%= puppy.description.length > 70 ? '...' : '' %></p>
              <% } %>
              <div class="card-footer">
                <span class="card-price">$<%= puppy.price %></span>
                <span class="card-view-link">View Details <i class="fa-solid fa-arrow-right"></i></span>
              </div>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var state = { gender: 'all', status: 'all' };
    var groups = document.querySelectorAll('.filter-segment-group');
    var cards = document.querySelectorAll('.puppy-card-link');
    var emptyMsg = document.getElementById('filterEmptyMsg');
    var clearBtn = document.getElementById('clearFiltersBtn');

    groups.forEach(function(group) {
      var type = group.dataset.filterType;
      group.querySelectorAll('.seg-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          state[type] = btn.dataset.value;
          group.querySelectorAll('.seg-btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          applyFilters();
        });
      });
    });

    clearBtn.addEventListener('click', function() {
      state = { gender: 'all', status: 'all' };
      groups.forEach(function(group) {
        group.querySelectorAll('.seg-btn').forEach(function(b) {
          b.classList.toggle('active', b.dataset.value === 'all');
        });
      });
      applyFilters();
    });

    function applyFilters() {
      var visibleCount = 0;
      cards.forEach(function(card) {
        var matchesGender = state.gender === 'all' || card.dataset.gender === state.gender;
        var matchesStatus = state.status === 'all' || card.dataset.status === state.status;
        var show = matchesGender && matchesStatus;
        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });
      emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
      clearBtn.style.display = (state.gender === 'all' && state.status === 'all') ? 'none' : 'inline-block';
    }
  });
</script>

<%- include('partials/footer') %>